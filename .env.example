# Rozi Dance — Variables d'environnement (exemple)
# Copier en .env.local et remplir les valeurs

# V1 — Vidéo hero YouTube
PUBLIC_HERO_VIDEO_ID=           # ID YouTube de la vidéo hero (ex: "dQw4w9WgXcQ")

# V2 — Contact
# PUBLIC_WEB3FORMS_KEY=         # Clé API Web3Forms pour le formulaire de contact
# PUBLIC_WHATSAPP_NUMBER=       # Numéro WhatsApp avec indicatif pays (ex: "32XXXXXXXXX")
