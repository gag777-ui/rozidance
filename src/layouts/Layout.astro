---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import PageLoader from '../components/ui/PageLoader.astro';
import Cursor from '../components/ui/Cursor.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Duo artistique arménien — chant, danse, cérémonies et cours.',
  ogTitle,
  ogDescription,
  ogImage = '/images/og-default.webp',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={Astro.currentLocale ?? 'fr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="fr_BE" />
    <meta property="og:site_name" content="Rozi Dance" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Google Fonts — non-render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=Inter:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=Inter:wght@400;500&display=swap"
      />
    </noscript>

    <!-- View Transitions (navigation instantanée entre pages) -->
    <ClientRouter />

    <!-- Schema.org JSON-LD -->
    <slot name="schema" />
  </head>

  <body>
    <PageLoader transition:persist />
    <Cursor transition:persist />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal + Loader + Dark mode persistence -->
    <script>
      // ── Fallback images (remplace onerror inline) ──
      function initImgFallbacks() {
        document.querySelectorAll<HTMLImageElement>('img[data-fallback]').forEach((img) => {
          img.addEventListener('error', () => {
            const fb = img.dataset.fallback;
            if (fb && img.src !== fb) img.src = fb;
          }, { once: true });
        });
      }
      initImgFallbacks();
      document.addEventListener('astro:page-load', initImgFallbacks);

      // ── Scroll reveal (ré-initialisé à chaque navigation) ──
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal:not(.is-visible), .reveal-fade:not(.is-visible), .reveal-left:not(.is-visible), .reveal-right:not(.is-visible), .reveal-scale:not(.is-visible)').forEach((el) => {
          observer.observe(el);
        });
      }

      // ── Page loader dismiss ──
      function dismissLoader() {
        const l = document.getElementById('page-loader');
        if (l) l.classList.add('loaded');
      }

      initReveal();
      dismissLoader();
      document.addEventListener('astro:page-load', () => {
        initReveal();
        dismissLoader();
      });

      // ── Scroll position au changement de page ──
      // scroll-behavior:smooth interfère avec View Transitions : on le coupe
      // pendant le swap pour que le scroll-to-top soit instantané.
      document.addEventListener('astro:before-swap', () => {
        document.documentElement.style.scrollBehavior = 'auto';
      });
      document.addEventListener('astro:after-swap', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
        }
        // Rétablit le smooth scroll après que le DOM est stable
        requestAnimationFrame(() => {
          document.documentElement.style.scrollBehavior = '';
        });
      });
    </script>
    <!-- GSAP + Lenis animations -->
    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      let lenis: InstanceType<typeof Lenis> | null = null;
      let rafFn: ((time: number) => void) | null = null;
      let magneticController: AbortController | null = null;

      function destroy() {
        if (rafFn) { gsap.ticker.remove(rafFn); rafFn = null; }
        if (lenis) { lenis.destroy(); lenis = null; }
        ScrollTrigger.getAll().forEach(t => t.kill());
        magneticController?.abort();
        magneticController = null;
      }

      function init() {
        destroy();

        // ── Lenis smooth scroll ──
        lenis = new Lenis({
          duration: 1.4,
          smoothWheel: true,
          prevent: (node: Element) => node.id === 'mobile-menu',
        });
        lenis.on('scroll', ScrollTrigger.update);
        rafFn = (time: number) => lenis!.raf(time * 1000);
        gsap.ticker.add(rafFn);
        gsap.ticker.lagSmoothing(0);
        document.documentElement.style.scrollBehavior = 'auto';

        // ── Hero parallax ──
        const heroVideo = document.querySelector<HTMLElement>('.hero-bg-video');
        const heroText  = document.querySelector<HTMLElement>('.hero-text');

        if (heroVideo) {
          gsap.to(heroVideo, {
            yPercent: 28,
            ease: 'none',
            scrollTrigger: {
              trigger: '.hero-section',
              start: 'top top',
              end: 'bottom top',
              scrub: 2,
            },
          });
        }

        if (heroText) {
          gsap.to(heroText, {
            y: -80,
            opacity: 0,
            ease: 'none',
            scrollTrigger: {
              trigger: '.hero-section',
              start: '38% top',
              end: 'bottom top',
              scrub: 1.5,
            },
          });
        }

        // ── Magnetic buttons ──
        magneticController = new AbortController();
        const { signal } = magneticController;

        document.querySelectorAll<HTMLElement>('.btn-primary, .btn-ghost, .hero-btn-ghost').forEach(btn => {
          btn.addEventListener('mousemove', (e) => {
            const ev = e as MouseEvent;
            const r = btn.getBoundingClientRect();
            const x = (ev.clientX - r.left - r.width / 2) * 0.3;
            const y = (ev.clientY - r.top  - r.height / 2) * 0.3;
            gsap.to(btn, { x, y, duration: 0.4, ease: 'power2.out', overwrite: 'auto' });
          }, { signal });

          btn.addEventListener('mouseleave', () => {
            gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.4)', overwrite: 'auto' });
          }, { signal });
        });

        // ── Section title word-by-word reveal ──
        document.querySelectorAll<HTMLElement>('.section-title:not([data-gsap-split])').forEach(title => {
          const parentHeader = title.closest('.section-header');
          if (!parentHeader) return;

          title.dataset.gsapSplit = 'true';
          const raw = title.innerHTML;

          // Wrap each word in a mask span
          title.innerHTML = raw.replace(
            /(<[^>]+>)|([^<\s][^<]*[^<\s]|[^<\s])/g,
            (match, tag, word) => {
              if (tag) return tag;
              return `<span class="tw-wrap" aria-hidden="true" style="display:inline-block;overflow:hidden;vertical-align:bottom"><span class="tw-inner" style="display:inline-block">${word}</span></span>`;
            }
          );

          const inners = title.querySelectorAll<HTMLElement>('.tw-inner');
          gsap.set(inners, { yPercent: 105 });

          ScrollTrigger.create({
            trigger: parentHeader,
            start: 'top 82%',
            once: true,
            onEnter: () => {
              gsap.to(inners, {
                yPercent: 0,
                duration: 0.75,
                stagger: 0.055,
                ease: 'power3.out',
                delay: 0.15,
              });
            },
          });
        });
      }

      // First load + View Transitions
      init();
      document.addEventListener('astro:before-swap', destroy);
      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
