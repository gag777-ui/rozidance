---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'ru' } },
  ];
}

const lang = (Astro.currentLocale ?? Astro.params.lang ?? 'fr') as Lang;
const t = getTranslations(lang);
const faq = t.cours.faqItems;
---

<Layout title={t.cours.pageTitle} description={t.cours.pageDescription}>
  <!-- Hero -->
  <section class="cours-hero" aria-labelledby="cours-title">
    <div class="section-container cours-hero-inner">
      <span class="eyebrow">{t.cours.heroEyebrow}</span>
      <h1 id="cours-title">{t.cours.heroTitle}</h1>
      <p class="cours-hero-subtitle">{t.cours.heroSubtitle}</p>
    </div>
  </section>

  <!-- 6 cours cards -->
  <section class="cours-cards-section">
    <div class="section-container">
      <div class="cours-cards-grid">
        {t.cours.cards.map((card, i) => (
          <a
            href={`/${lang}/cours/${card.slug}`}
            class="cours-card reveal"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="card-accent-bar"></div>
            <div class="card-body">
              <span class="card-ordinal" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="card-thumb">
                <img src="/images/reel-cover.webp" alt={card.title} loading="lazy" width="400" height="400" />
              </div>
              <h2 class="card-title">{card.title}</h2>
              <p class="card-desc">{card.description}</p>
              <span class="card-link">
                {t.cours.cardLink}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="card-arrow">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section chant -->
  <section class="cours-section" aria-labelledby="chant-title">
    <div class="section-container cours-section-inner">
      <div class="cours-text reveal">
        <h2 id="chant-title">{t.cours.chantTitle}</h2>
        <p>{t.cours.chantDescription}</p>
        <ul class="cours-list">
          {t.cours.chantList.map(item => <li>{item}</li>)}
        </ul>
      </div>
      <div class="cours-deco reveal" aria-hidden="true">
        <div class="cours-deco-circle"></div>
      </div>
    </div>
  </section>

  <!-- Section danse -->
  <section class="cours-section cours-section-alt" aria-labelledby="danse-title">
    <div class="section-container cours-section-inner reverse">
      <div class="cours-deco reveal" aria-hidden="true">
        <div class="cours-deco-circle danse-circle"></div>
      </div>
      <div class="cours-text reveal">
        <h2 id="danse-title">{t.cours.danseTitle}</h2>
        <p>{t.cours.danseDescription}</p>
        <ul class="cours-list">
          {t.cours.danseList.map(item => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cours-faq" aria-labelledby="faq-title">
    <div class="section-container">
      <div class="section-header reveal">
        <span class="eyebrow">{t.cours.faqEyebrow}</span>
        <h2 id="faq-title">{t.cours.faqTitle}</h2>
      </div>
      <div class="faq-list" id="faq-accordion">
        {faq.map((item: { q: string; a: string }, i: number) => (
          <details class="faq-item reveal" style={`transition-delay: ${i * 40}ms`}>
            <summary class="faq-question">
              {item.q}
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cours-cta" aria-labelledby="cta-title">
    <div class="section-container">
      <div class="cta-inner reveal">
        <h2 id="cta-title">{t.cours.ctaTitle}</h2>
        <p>{t.cours.ctaSubtitle}</p>
        <a href={`/${lang}#contact`} class="btn-primary">{t.cours.ctaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cours-hero { padding-block: 5rem 3.5rem; background-color: var(--color-bg-card); }
  .cours-hero-inner { display: flex; flex-direction: column; gap: 1rem; max-width: 700px; }
  .cours-hero-inner h1 { font-size: clamp(2.5rem, 5vw, 4rem); color: var(--color-text-primary); margin: 0; }
  .cours-hero-subtitle { font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0; }

  .cours-cards-section { padding-block: var(--spacing-section); }

  .cours-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 600px) { .cours-cards-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cours-cards-grid { grid-template-columns: repeat(3, 1fr); } }

  .cours-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    transition: transform 400ms var(--ease-out-soft), border-color 400ms var(--ease-out-soft), box-shadow 400ms var(--ease-out-soft);
  }

  .cours-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 32px rgba(193, 104, 71, 0.12);
  }

  .cours-card .card-accent-bar {
    height: 3px;
    background: linear-gradient(to right, var(--color-accent), var(--color-gold));
    flex-shrink: 0;
  }

  .cours-card .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
    position: relative;
  }

  .cours-card .card-ordinal {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-family: var(--font-serif);
    font-size: 3rem;
    line-height: 1;
    color: var(--color-border);
    pointer-events: none;
    user-select: none;
    transition: color 400ms var(--ease-out-soft);
  }

  .cours-card:hover .card-ordinal { color: rgba(193, 104, 71, 0.1); }

  .cours-card .card-thumb {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    border: 0.5px solid var(--color-border);
    flex-shrink: 0;
  }

  .cours-card .card-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .cours-card .card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .cours-card .card-desc { font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.6; margin: 0; flex: 1; }

  .cours-card .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: 0.25rem;
    transition: gap 250ms var(--ease-out-soft);
  }

  .cours-card:hover .card-link { gap: 0.75rem; }

  .cours-card .card-arrow { flex-shrink: 0; transition: transform 250ms var(--ease-out-soft); }
  .cours-card:hover .card-arrow { transform: translateX(3px); }

  .cours-section { padding-block: 5rem; }
  .cours-section-alt { background-color: var(--color-bg-card); }

  .cours-section-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .cours-section-inner.reverse { direction: rtl; }
  .cours-section-inner.reverse > * { direction: ltr; }

  .cours-text h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); color: var(--color-text-primary); margin: 0 0 1.25rem; }
  .cours-text p { font-size: 1rem; color: var(--color-text-secondary); line-height: 1.75; margin: 0 0 1.5rem; }

  .cours-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cours-list li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .cours-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 1.25rem;
    line-height: 1;
    top: 0.1em;
  }

  .cours-deco-circle {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%);
    opacity: 0.06;
    margin-inline: auto;
  }

  .danse-circle { background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%); }

  .section-header { text-align: center; margin-bottom: 3rem; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
  .section-header h2 { font-size: clamp(1.875rem, 3.5vw, 2.75rem); color: var(--color-text-primary); margin: 0; }

  .cours-faq { padding-block: 5rem; background-color: var(--color-bg-card); }

  .faq-list { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 0.5px solid var(--color-border); }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-chevron { font-size: 1.25rem; color: var(--color-accent); transition: transform 300ms var(--ease-out-soft); flex-shrink: 0; }
  details[open] .faq-chevron { transform: rotate(45deg); }

  .faq-answer { font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.75; margin: 0; padding-bottom: 1.25rem; padding-right: 2rem; }

  .cours-cta { padding-block: 5rem; }

  .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
  .cta-inner h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); color: var(--color-text-primary); margin: 0; }
  .cta-inner p { font-size: 1rem; color: var(--color-text-secondary); margin: 0; max-width: 45ch; line-height: 1.65; }

  @media (max-width: 900px) {
    .cours-section-inner { grid-template-columns: 1fr; gap: 2rem; }
    .cours-section-inner.reverse { direction: ltr; }
    .cours-deco { display: none; }
  }
</style>
