---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);

const COVER = '/images/reel-cover.webp';

const reels = [
  {
    url: 'https://www.instagram.com/reel/DTvKVC2irei/?igsh=YmZvYnZjcW05YzJw',
    cover: COVER,
    title: 'Aperçu de nos prestations',
    description: 'Un avant-goût de ce que nous vivons ensemble.',
  },
  {
    url: 'https://www.instagram.com/reel/DUDvZQPCrNU/?igsh=Y3V1N3I2ZTIyZ29u',
    cover: COVER,
    title: 'La joie de partager',
    description: 'Ces moments qui restent gravés dans les cœurs.',
  },
  {
    url: 'https://www.instagram.com/reel/DR1unSWDMTp/?igsh=MTdyb29lOTFkczZrNA%3D%3D',
    cover: COVER,
    title: 'Le plaisir d\'être ensemble',
    description: 'Quand la musique réunit les gens.',
  },
  {
    url: 'https://www.instagram.com/reel/DKxHqISI1Wp/?igsh=d3A3YWJ0Y2lzanJr',
    cover: COVER,
    title: 'Nos belles rencontres',
    description: 'Chaque événement est une nouvelle histoire.',
  },
  {
    url: 'https://www.instagram.com/reel/DKpyjmmot4i/?igsh=MXR3cGk4cDBzc3E0ZQ%3D%3D',
    cover: COVER,
    title: 'Des souvenirs inoubliables',
    description: 'Ce que l\'on crée ensemble ne s\'oublie pas.',
  },
  {
    url: 'https://www.instagram.com/p/DIUSq1RoOJD/?igsh=c29naDl0d3Y4bnVn',
    cover: COVER,
    title: 'L\'art de célébrer',
    description: 'La danse et le chant au service de vos émotions.',
  },
  {
    url: 'https://www.instagram.com/reel/CzYCxokosLj/?igsh=NndycW1na2IwczM3',
    cover: COVER,
    title: 'Vibrer ensemble',
    description: 'Des prestations qui touchent, qui émeuvent, qui font danser.',
  },
  {
    url: 'https://www.instagram.com/reel/C-Bbdt6Iy94/?igsh=MWdsMTlndDY5bjdrag%3D%3D',
    cover: COVER,
    title: 'La tradition en mouvement',
    description: 'Notre héritage arménien, partagé avec amour.',
  },
];
---

<Layout
  title="Mariages & célébrations — Rozi Dance"
  description="Prestations de chant et danse arméniens pour mariages, baptêmes et célébrations. Découvrez nos performances en vidéo."
>
  <!-- Hero de page -->
  <section class="page-hero">
    <div class="section-container page-hero-inner">
      <a href="/#prestations" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Retour
      </a>
      <span class="eyebrow">Nos prestations</span>
      <h1>Mariages & célébrations</h1>
      <p class="page-hero-subtitle">Chant, danse et animations pour vos plus beaux moments — sur mesure, en plusieurs langues, partout en Europe.</p>
    </div>
  </section>

  <!-- Grille de reels -->
  <section class="reels-section">
    <div class="section-container">
      <div class="reels-grid">
        {reels.map((reel, i) => (
          <a
            href={reel.url}
            target="_blank"
            rel="noopener noreferrer"
            class="reel-card reveal"
            style={`transition-delay: ${i * 80}ms`}
            aria-label={`Voir le reel Instagram : ${reel.title}`}
          >
            <div class="reel-cover">
              <img
                src={reel.cover}
                alt={reel.title}
                loading="lazy"
                decoding="async"
                data-fallback="/images/placeholder.webp"
              />
              <div class="reel-overlay">
                <svg class="reel-insta-icon" width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
                <span class="reel-play-label">Voir le reel</span>
              </div>
            </div>
            <div class="reel-body">
              <h3 class="reel-title">{reel.title}</h3>
              <p class="reel-desc">{reel.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA contact -->
  <section class="mariages-cta">
    <div class="section-container mariages-cta-inner">
      <p class="mariages-cta-text">Vous avez un événement en vue ?</p>
      <a href="/#contact" class="btn-primary">Nous contacter</a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero de page ── */
  .page-hero {
    background-color: var(--color-bg-primary);
    padding-block: 3rem 2.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .page-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 13px;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: color 250ms;
  }
  .back-link:hover { color: var(--color-accent); }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.1;
  }

  .page-hero-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 52ch;
    line-height: 1.65;
    margin: 0;
  }

  /* ── Grille reels ── */
  .reels-section {
    padding-block: 3.5rem 4rem;
    background-color: var(--color-bg-primary);
  }

  .reels-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem 1.5rem;
  }

  .reel-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    background: transparent;
    border: none;
    transition: transform 400ms var(--ease-out-soft);
  }

  .reel-card:hover {
    transform: translateY(-4px);
  }

  .reel-cover {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    background-color: var(--color-bg-card);
    box-shadow: 0 4px 20px rgba(193, 104, 71, 0.15);
    transition: box-shadow 400ms var(--ease-out-soft);
  }

  .reel-card:hover .reel-cover {
    box-shadow: 0 8px 32px rgba(193, 104, 71, 0.28);
  }

  .reel-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transition: transform 600ms var(--ease-out-soft);
  }

  .reel-card:hover .reel-cover img {
    transform: scale(1.06);
  }

  .reel-overlay {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(43, 31, 21, 0);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    opacity: 0;
    transition: opacity 350ms var(--ease-out-soft),
                background 350ms var(--ease-out-soft);
  }

  .reel-card:hover .reel-overlay {
    opacity: 1;
    background: rgba(43, 31, 21, 0.45);
  }

  .reel-insta-icon {
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
  }

  .reel-play-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
  }

  .reel-body {
    padding: 0.75rem 0.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .reel-title {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .reel-desc {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* ── CTA ── */
  .mariages-cta {
    background-color: var(--color-bg-card);
    border-top: 0.5px solid var(--color-border);
    padding-block: 3rem;
  }

  .mariages-cta-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
  }

  .mariages-cta-text {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .reels-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 700px) {
    .reels-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .reels-grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-inline: auto;
    }
  }
</style>
