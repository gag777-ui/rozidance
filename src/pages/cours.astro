---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/utils';
const t = getTranslations('fr');

const tarifsChant = [
  { formule: 'Séance individuelle (1h)', prix: '60 €' },
  { formule: 'Forfait 10 séances individuelles', prix: '540 €' },
  { formule: 'Cours en groupe (par personne)', prix: '25 €' },
];

const tarifsDanse = [
  { formule: 'Séance individuelle (1h)', prix: '55 €' },
  { formule: 'Forfait 10 séances individuelles', prix: '490 €' },
  { formule: 'Cours en groupe (par personne)', prix: '20 €' },
];

const faq = [
  {
    q: 'Faut-il déjà savoir chanter pour s\'inscrire aux cours ?',
    a: 'Pas du tout ! Nos cours s\'adressent à tous les niveaux, du grand débutant au chanteur confirmé souhaitant se spécialiser dans le répertoire arménien.',
  },
  {
    q: 'Les cours se font-ils en arménien ?',
    a: 'Les cours peuvent se dérouler en français, russe ou arménien selon votre préférence. Les chants sont bien sûr enseignés dans leur langue originale (arménien), avec explication des textes.',
  },
  {
    q: 'Les cours à distance sont-ils possibles ?',
    a: 'Oui, nous proposons des cours en visioconférence (Zoom, Google Meet). Cette formule est disponible pour les cours individuels de chant et de danse.',
  },
  {
    q: 'Combien de temps faut-il pour apprendre un chant ?',
    a: 'En général, un chant simple peut être appris en 2 à 4 séances. Les pièces plus complexes demandent plus de temps. Tout dépend de votre niveau et de votre pratique entre les cours.',
  },
  {
    q: 'Proposez-vous des cours pour préparer un chant de mariage ?',
    a: 'Absolument ! C\'est l\'une de nos spécialités. Nous pouvons vous préparer à chanter lors de votre propre cérémonie de mariage, avec un programme sur mesure adapté à votre calendrier.',
  },
  {
    q: 'Les cours de danse sont-ils adaptés aux débutants ?',
    a: 'Oui, tous nos cours de danse débutent par les bases. Aucune expérience préalable en danse n\'est nécessaire. Nous avançons à votre rythme.',
  },
  {
    q: 'Peut-on combiner cours de chant et cours de danse ?',
    a: 'Tout à fait, et c\'est même ce que nous recommandons ! Un tarif combiné est disponible, contactez-nous pour un devis personnalisé.',
  },
  {
    q: 'Les cours en groupe ont-ils un nombre minimum de participants ?',
    a: 'Les cours en groupe démarrent à partir de 4 personnes. Ils sont idéaux pour les associations culturelles, groupes d\'amis ou préparations d\'événements.',
  },
  {
    q: 'Peut-on offrir des cours en cadeau ?',
    a: 'Oui, nous proposons des bons cadeaux pour des séances individuelles ou des forfaits. Contactez-nous par e-mail pour en commander un.',
  },
  {
    q: 'Comment payer ?',
    a: 'Nous acceptons le virement bancaire (BE) et le cash pour les cours en présentiel. Les modalités sont précisées lors de l\'inscription.',
  },
];
---

<Layout
  title={t.cours.pageTitle}
  description={t.cours.pageDescription}
>
  <!-- Page hero -->
  <section class="cours-hero" aria-labelledby="cours-title">
    <div class="section-container cours-hero-inner">
      <span class="eyebrow">{t.cours.heroEyebrow}</span>
      <h1 id="cours-title">{t.cours.heroTitle}</h1>
      <p class="cours-hero-subtitle">{t.cours.heroSubtitle}</p>
    </div>
  </section>

  <!-- Section chant -->
  <section class="cours-section" aria-labelledby="chant-title">
    <div class="section-container cours-section-inner">
      <div class="cours-text reveal">
        <h2 id="chant-title">{t.cours.chantTitle}</h2>
        <p>{t.cours.chantDescription}</p>
        <ul class="cours-list">
          <li>Répertoire arménien traditionnel</li>
          <li>Chants internationaux populaires</li>
          <li>Technique vocale adaptée à votre voix</li>
          <li>Tous niveaux — débutant à avancé</li>
          <li>Cours individuels ou en groupe</li>
          <li>En présentiel ou à distance</li>
        </ul>
      </div>
      <div class="cours-deco reveal" aria-hidden="true">
        <div class="cours-deco-circle"></div>
      </div>
    </div>
  </section>

  <!-- Section danse -->
  <section class="cours-section cours-section-alt" aria-labelledby="danse-title">
    <div class="section-container cours-section-inner reverse">
      <div class="cours-deco reveal" aria-hidden="true">
        <div class="cours-deco-circle danse-circle"></div>
      </div>
      <div class="cours-text reveal">
        <h2 id="danse-title">{t.cours.danseTitle}</h2>
        <p>{t.cours.danseDescription}</p>
        <ul class="cours-list">
          <li>Danses folkloriques arméniennes</li>
          <li>Chorégraphies pour événements</li>
          <li>Danse en groupe et individuelle</li>
          <li>Tous niveaux, tous âges</li>
          <li>Ambiance chaleureuse et bienveillante</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Tarifs -->
  <section class="cours-tarifs" aria-labelledby="tarifs-title">
    <div class="section-container">
      <div class="section-header reveal">
        <span class="eyebrow">{t.cours.tarifsEyebrow}</span>
        <h2 id="tarifs-title">{t.cours.tarifsTitle}</h2>
      </div>

      <div class="tarifs-grid">
        <!-- Chant -->
        <div class="tarif-block card reveal">
          <h3 class="tarif-block-title">Cours de chant</h3>
          <table class="tarif-table">
            <thead>
              <tr>
                <th>Formule</th>
                <th>Tarif</th>
              </tr>
            </thead>
            <tbody>
              {tarifsChant.map((row) => (
                <tr>
                  <td>{row.formule}</td>
                  <td class="tarif-prix">{row.prix}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Danse -->
        <div class="tarif-block card reveal" style="transition-delay: 120ms">
          <h3 class="tarif-block-title">Cours de danse</h3>
          <table class="tarif-table">
            <thead>
              <tr>
                <th>Formule</th>
                <th>Tarif</th>
              </tr>
            </thead>
            <tbody>
              {tarifsDanse.map((row) => (
                <tr>
                  <td>{row.formule}</td>
                  <td class="tarif-prix">{row.prix}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="tarif-note">* Tarif combiné chant + danse disponible sur demande.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cours-faq" aria-labelledby="faq-title">
    <div class="section-container">
      <div class="section-header reveal">
        <span class="eyebrow">{t.cours.faqEyebrow}</span>
        <h2 id="faq-title">{t.cours.faqTitle}</h2>
      </div>

      <div class="faq-list" id="faq-accordion">
        {faq.map((item, i) => (
          <details class="faq-item reveal" style={`transition-delay: ${i * 40}ms`}>
            <summary class="faq-question">
              {item.q}
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cours-cta" aria-labelledby="cta-title">
    <div class="section-container">
      <div class="cta-inner reveal">
        <h2 id="cta-title">{t.cours.ctaTitle}</h2>
        <p>{t.cours.ctaSubtitle}</p>
        <a href="/#contact" class="btn-primary">{t.cours.ctaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .cours-hero {
    padding-block: 5rem 3.5rem;
    background-color: var(--color-bg-card);
  }

  .cours-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
  }

  .cours-hero-inner h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .cours-hero-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Section chant / danse */
  .cours-section {
    padding-block: 5rem;
  }

  .cours-section-alt {
    background-color: var(--color-bg-card);
  }

  .cours-section-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .cours-section-inner.reverse {
    direction: rtl;
  }

  .cours-section-inner.reverse > * {
    direction: ltr;
  }

  .cours-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }

  .cours-text p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 1.5rem;
  }

  .cours-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cours-list li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .cours-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 1.25rem;
    line-height: 1;
    top: 0.1em;
  }

  .cours-deco-circle {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%);
    opacity: 0.06;
    margin-inline: auto;
  }

  .danse-circle {
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
  }

  /* Tarifs */
  .cours-tarifs {
    padding-block: 5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .tarifs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .tarif-block {
    padding: 2rem;
  }

  .tarif-block-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }

  .tarif-table {
    width: 100%;
    border-collapse: collapse;
  }

  .tarif-table th {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    text-align: left;
    padding-bottom: 0.75rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .tarif-table td {
    padding: 0.75rem 0;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border);
  }

  .tarif-prix {
    font-family: var(--font-serif);
    font-size: 1.0625rem !important;
    color: var(--color-text-primary) !important;
    text-align: right;
    white-space: nowrap;
  }

  .tarif-note {
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 1rem 0 0;
    line-height: 1.5;
  }

  /* FAQ */
  .cours-faq {
    padding-block: 5rem;
    background-color: var(--color-bg-card);
  }

  .faq-list {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    font-size: 1.25rem;
    color: var(--color-accent);
    transition: transform 300ms var(--ease-out-soft);
    flex-shrink: 0;
    line-height: 1;
  }

  details[open] .faq-chevron {
    transform: rotate(45deg);
  }

  .faq-answer {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
    padding-bottom: 1.25rem;
    padding-right: 2rem;
  }

  /* CTA */
  .cours-cta {
    padding-block: 5rem;
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .cta-inner h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .cta-inner p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 45ch;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .cours-section-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .cours-section-inner.reverse {
      direction: ltr;
    }

    .tarifs-grid {
      grid-template-columns: 1fr;
    }

    .cours-deco {
      display: none;
    }
  }
</style>
