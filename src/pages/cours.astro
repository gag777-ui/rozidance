---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
const base = lang === 'fr' ? '' : `/${lang}`;

const faq = t.cours.faqItems;

const coursCards = [
  { slug: 'chant-armenien', title: 'Chant arménien', description: 'Nous sommes fiers de transmettre notre art et notre passion à chaque élève, quel que soit son niveau.' },
  { slug: 'chant-jazz-soul-pop', title: 'Chant Jazz · Soul · Pop', description: 'Nous sommes fiers de transmettre notre art et notre passion à chaque élève, quel que soit son niveau.' },
  { slug: 'chant-de-mariage', title: 'Chant de mariage', description: 'Nous sommes fiers de transmettre notre art et notre passion à chaque élève, quel que soit son niveau.' },
  { slug: 'danse-armenienne', title: 'Danse arménienne', description: 'Nous sommes fiers de transmettre notre art et notre passion à chaque élève, quel que soit son niveau.' },
  { slug: 'danse-en-groupe', title: 'Danse en groupe', description: 'Nous sommes fiers de transmettre notre art et notre passion à chaque élève, quel que soit son niveau.' },
  { slug: 'cours-en-ligne', title: 'Cours en ligne', description: 'Nous sommes fiers de transmettre notre art et notre passion à chaque élève, quel que soit son niveau.' },
];
---

<Layout
  title={t.cours.pageTitle}
  description={t.cours.pageDescription}
>
  <!-- Page hero -->
  <section class="cours-hero" aria-labelledby="cours-title">
    <div class="section-container cours-hero-inner">
      <a href={`${base || '/'}#prestations`} class="back-link">
        <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M12 7H2M6 3l-4 4 4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {t.nav.prestations}
      </a>
      <span class="eyebrow">{t.cours.heroEyebrow}</span>
      <h1 id="cours-title">{t.cours.heroTitle}</h1>
      <p class="cours-hero-subtitle">{t.cours.heroSubtitle}</p>
    </div>
  </section>

  <!-- 6 cours cards -->
  <section class="cours-cards-section">
    <div class="section-container">
      <div class="cours-cards-grid">
        {coursCards.map((card, i) => (
          <a
            href={`${base}/cours/${card.slug}`}
            class={`card-shell cs-${i % 3} reveal`}
            style={`transition-delay: ${i * 80}ms`}
            data-card
          >
            <div class={`card-core cc-${i % 3}`}>
              <div class="card-light"></div>
              <div class="card-top">
                <span class="card-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <div class="card-thumb">
                  <img src="/images/reel-cover.webp" alt={card.title} loading="lazy" width="400" height="400" />
                </div>
              </div>
              <h2 class="card-title">{card.title}</h2>
              <div class="card-line"></div>
              <p class="card-desc">{card.description}</p>
              <span class="card-cta">
                Voir les vidéos
                <span class="cta-circle" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section chant -->
  <section class="cours-section" aria-labelledby="chant-title">
    <div class="section-container cours-section-inner">
      <div class="cours-text reveal">
        <h2 id="chant-title">{t.cours.chantTitle}</h2>
        <p>{t.cours.chantDescription}</p>
        <ul class="cours-list">
          <li>Répertoire arménien traditionnel</li>
          <li>Chants internationaux populaires</li>
          <li>Technique vocale adaptée à votre voix</li>
          <li>Tous niveaux — débutant à avancé</li>
          <li>Cours individuels ou en groupe</li>
          <li>En présentiel ou à distance</li>
        </ul>
      </div>
      <div class="cours-deco reveal" aria-hidden="true">
        <div class="cours-deco-circle"></div>
      </div>
    </div>
  </section>

  <!-- Section danse -->
  <section class="cours-section cours-section-alt" aria-labelledby="danse-title">
    <div class="section-container cours-section-inner reverse">
      <div class="cours-deco reveal" aria-hidden="true">
        <div class="cours-deco-circle danse-circle"></div>
      </div>
      <div class="cours-text reveal">
        <h2 id="danse-title">{t.cours.danseTitle}</h2>
        <p>{t.cours.danseDescription}</p>
        <ul class="cours-list">
          <li>Danses folkloriques arméniennes</li>
          <li>Chorégraphies pour événements</li>
          <li>Danse en groupe et individuelle</li>
          <li>Tous niveaux, tous âges</li>
          <li>Ambiance chaleureuse et bienveillante</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Tilt script -->
  <script>
    function initCoursTilt() {
      const shells = document.querySelectorAll<HTMLElement>('[data-card]');
      const ac = new AbortController(); const { signal } = ac;
      const rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      shells.forEach(shell => {
        const light = shell.querySelector<HTMLElement>('.card-light');
        let startX = 0, startY = 0, hasMoved = false;
        shell.addEventListener('touchstart', (e: TouchEvent) => { if (rm) return; startX = e.touches[0].clientX; startY = e.touches[0].clientY; hasMoved = false; }, { passive: true, signal });
        shell.addEventListener('touchmove', (e: TouchEvent) => {
          if (rm) return;
          const t = e.touches[0];
          if (Math.abs(t.clientX - startX) < 8 && Math.abs(t.clientY - startY) < 8) return;
          hasMoved = true;
          shell.style.transition = 'transform 80ms linear';
          const r = shell.getBoundingClientRect();
          const dx = (t.clientX - r.left - r.width/2)/(r.width/2), dy = (t.clientY - r.top - r.height/2)/(r.height/2);
          shell.style.transform = `perspective(900px) rotateX(${-dy*10}deg) rotateY(${dx*14}deg) translateZ(6px)`;
          if (light) { light.style.setProperty('--lx',`${50+dx*30}%`); light.style.setProperty('--ly',`${50-dy*22}%`); }
        }, { passive: true, signal });
        const reset = () => {
          if (!hasMoved) { shell.style.transition = 'none'; shell.style.transform = 'perspective(900px) rotateX(0deg) rotateY(0deg)'; }
          else { shell.style.transition = 'transform 500ms var(--ease-out-soft)'; shell.style.transform = 'perspective(900px) rotateX(0deg) rotateY(0deg)'; if (light) { light.style.setProperty('--lx','28%'); light.style.setProperty('--ly','22%'); } }
          hasMoved = false;
        };
        shell.addEventListener('touchend', reset, { passive: true, signal });
        shell.addEventListener('touchcancel', reset, { passive: true, signal });
        shell.addEventListener('mousemove', (e: MouseEvent) => {
          if (rm) return; const r = shell.getBoundingClientRect();
          const dx = (e.clientX-r.left-r.width/2)/(r.width/2), dy = (e.clientY-r.top-r.height/2)/(r.height/2);
          shell.style.transition = 'transform 100ms linear';
          shell.style.transform = `perspective(900px) rotateX(${-dy*7}deg) rotateY(${dx*10}deg) translateZ(4px)`;
          if (light) { light.style.setProperty('--lx',`${50+dx*20}%`); light.style.setProperty('--ly',`${50-dy*14}%`); }
        }, { signal });
        shell.addEventListener('mouseleave', () => { shell.style.transition = 'transform 600ms var(--ease-out-soft)'; shell.style.transform = 'perspective(900px) rotateX(0deg) rotateY(0deg)'; if (light) { light.style.setProperty('--lx','28%'); light.style.setProperty('--ly','22%'); } }, { signal });
      });
      document.addEventListener('astro:before-swap', () => ac.abort(), { once: true });
    }
    document.addEventListener('astro:page-load', initCoursTilt);
  </script>

  <!-- FAQ -->
  <section class="cours-faq" aria-labelledby="faq-title">
    <div class="section-container">
      <div class="section-header reveal">
        <span class="eyebrow">{t.cours.faqEyebrow}</span>
        <h2 id="faq-title">{t.cours.faqTitle}</h2>
      </div>

      <div class="faq-list" id="faq-accordion">
        {faq.map((item, i) => (
          <details class="faq-item reveal" style={`transition-delay: ${i * 40}ms`}>
            <summary class="faq-question">
              {item.q}
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cours-cta" aria-labelledby="cta-title">
    <div class="section-container">
      <div class="cta-inner reveal">
        <h2 id="cta-title">{t.cours.ctaTitle}</h2>
        <p>{t.cours.ctaSubtitle}</p>
        <a href="/#contact" class="btn-primary">{t.cours.ctaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .cours-hero {
    padding-block: 5rem 3.5rem;
    background-color: var(--color-bg-card);
  }

  .cours-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 0.25rem;
    min-height: 44px;
    padding: 0.5rem 0;
    transition: color 220ms var(--ease-out-soft), gap 220ms var(--ease-out-soft);
    -webkit-tap-highlight-color: transparent;
  }
  .back-link:hover { color: var(--color-accent); gap: 0.75rem; }

  .cours-hero-inner h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .cours-hero-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Cards grid */
  .cours-cards-section { padding-block: var(--spacing-section); }

  .cours-cards-grid {
    display: flex; flex-direction: column;
    gap: 0.85rem; max-width: 420px; margin-inline: auto;
  }
  @media (min-width: 600px) { .cours-cards-grid { display: grid; grid-template-columns: repeat(2, 1fr); max-width: 640px; gap: 1rem; } }
  @media (min-width: 1024px) { .cours-cards-grid { grid-template-columns: repeat(3, 1fr); max-width: 100%; gap: 1.25rem; } }

  .card-shell {
    border-radius: 20px; padding: 5px;
    border: 0.5px solid rgba(229,215,190,0.6);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(43,31,21,0.04);
    transform-style: preserve-3d;
    transform: perspective(900px) rotateX(0deg) rotateY(0deg);
    transition: transform 500ms var(--ease-out-soft), box-shadow 500ms var(--ease-out-soft);
    will-change: transform; text-decoration: none; display: block;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  .cs-0 { background: rgba(168,135,83,0.07); }
  .cs-1 { background: rgba(193,104,71,0.07); }
  .cs-2 { background: rgba(122,92,32,0.06); }

  .card-core {
    border-radius: 15px; padding: 1.1rem 1.25rem;
    display: flex; flex-direction: column; gap: 0.65rem;
    position: relative; overflow: hidden;
  }
  .cc-0 { background: linear-gradient(145deg, #FEFCF8 0%, #EDDEB8 100%); }
  .cc-1 { background: linear-gradient(145deg, #FEFCF8 0%, #F0CBBA 100%); }
  .cc-2 { background: linear-gradient(145deg, #FEFCF8 0%, #E6D8A8 100%); }

  .card-light {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(circle at var(--lx,28%) var(--ly,22%), rgba(255,255,255,0.38) 0%, rgba(255,255,255,0.1) 35%, transparent 65%);
    border-radius: inherit; transition: background 80ms linear;
  }

  .card-top { display: flex; align-items: center; justify-content: space-between; position: relative; }
  .card-num { font-family: var(--font-serif); font-size: 2.5rem; font-weight: 200; font-style: italic; line-height: 1; color: rgba(43,31,21,0.09); user-select: none; pointer-events: none; }
  .card-thumb { width: 48px; height: 48px; border-radius: 50%; overflow: hidden; border: 0.5px solid rgba(229,215,190,0.7); flex-shrink: 0; }
  .card-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-title { font-family: var(--font-serif); font-size: 1.25rem; font-weight: 300; font-style: italic; color: var(--color-text-primary); margin: 0; line-height: 1.2; position: relative; }
  .card-line { height: 0.5px; background: linear-gradient(90deg, var(--color-border), transparent); position: relative; }
  .card-desc { font-size: 0.95rem; color: var(--color-text-secondary); line-height: 1.72; margin: 0; flex: 1; position: relative; }
  .card-cta { display: inline-flex; align-items: center; gap: 0.55rem; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; font-style: normal; font-weight: 500; text-decoration: none; color: var(--color-accent); padding: 0.5rem 0.6rem 0.5rem 0.9rem; min-height: 44px; border-radius: 999px; background: rgba(255,255,255,0.5); border: 0.5px solid rgba(255,255,255,0.85); box-shadow: inset 0 1px 0 rgba(255,255,255,0.95), 0 1px 4px rgba(43,31,21,0.06); align-self: flex-start; margin-top: 0.2rem; position: relative; overflow: hidden; cursor: pointer; transition: background 300ms var(--ease-out-soft), gap 300ms var(--ease-out-soft); }
  .card-cta::before { content: ''; position: absolute; top: 0; left: -80%; width: 55%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); animation: cta-shimmer 4s ease-in-out infinite; pointer-events: none; }
  @keyframes cta-shimmer { 0% { left: -80%; } 30% { left: 130%; } 100% { left: 130%; } }
  .card-shell:nth-child(2) .card-cta::before { animation-delay: 1.3s; }
  .card-shell:nth-child(3) .card-cta::before { animation-delay: 2.6s; }
  .card-shell:nth-child(4) .card-cta::before { animation-delay: 3.5s; }
  .card-shell:nth-child(5) .card-cta::before { animation-delay: 0.7s; }
  .card-shell:nth-child(6) .card-cta::before { animation-delay: 2s; }
  .cs-0 .card-cta { color: var(--color-gold); }
  .cs-2 .card-cta { color: #7A5C20; }
  .card-cta:hover { background: rgba(255,255,255,0.78); gap: 0.8rem; }
  .cta-circle { width: 28px; height: 28px; border-radius: 50%; border: 1px solid currentColor; opacity: 0.75; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 350ms var(--ease-out-soft), opacity 300ms; animation: arrow-nudge 4s ease-in-out infinite; }
  @keyframes arrow-nudge { 0%, 50%, 100% { transform: translateX(0); } 62% { transform: translateX(4px); } 70% { transform: translateX(1px); } 78% { transform: translateX(3px); } 86% { transform: translateX(0); } }
  .card-shell:nth-child(2) .cta-circle { animation-delay: 1.3s; }
  .card-shell:nth-child(3) .cta-circle { animation-delay: 2.6s; }
  .card-shell:nth-child(4) .cta-circle { animation-delay: 3.5s; }
  .card-shell:nth-child(5) .cta-circle { animation-delay: 0.7s; }
  .card-shell:nth-child(6) .cta-circle { animation-delay: 2s; }
  .card-cta:hover .cta-circle, .card-cta:focus .cta-circle { opacity: 1; transform: translateX(4px); animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) { .card-cta::before { animation: none; } .cta-circle { animation: none; } }

  /* Section chant / danse */
  .cours-section {
    padding-block: 5rem;
  }

  .cours-section-alt {
    background-color: var(--color-bg-card);
  }

  .cours-section-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .cours-section-inner.reverse {
    direction: rtl;
  }

  .cours-section-inner.reverse > * {
    direction: ltr;
  }

  .cours-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }

  .cours-text p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 1.5rem;
  }

  .cours-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cours-list li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .cours-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 1.25rem;
    line-height: 1;
    top: 0.1em;
  }

  .cours-deco-circle {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%);
    opacity: 0.06;
    margin-inline: auto;
  }

  .danse-circle {
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* FAQ */
  .cours-faq {
    padding-block: 5rem;
    background-color: var(--color-bg-card);
  }

  .faq-list {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    font-size: 1.25rem;
    color: var(--color-accent);
    transition: transform 300ms var(--ease-out-soft);
    flex-shrink: 0;
    line-height: 1;
  }

  details[open] .faq-chevron {
    transform: rotate(45deg);
  }

  .faq-answer {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
    padding-bottom: 1.25rem;
    padding-right: 2rem;
  }

  /* CTA */
  .cours-cta {
    padding-block: 5rem;
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .cta-inner h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .cta-inner p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 45ch;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .cours-section-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .cours-section-inner.reverse {
      direction: ltr;
    }

    .cours-deco {
      display: none;
    }
  }
</style>
