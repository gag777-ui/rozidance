---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import SectionHero from '../components/sections/SectionHero.astro';
import SectionPrestations from '../components/sections/SectionPrestations.astro';
import SectionGalerie from '../components/sections/SectionGalerie.astro';
import SectionVideos from '../components/sections/SectionVideos.astro';
import SectionApropos from '../components/sections/SectionApropos.astro';
import SectionStats from '../components/sections/SectionStats.astro';
import SectionTemoignages from '../components/sections/SectionTemoignages.astro';
import SectionFAQ from '../components/sections/SectionFAQ.astro';
import SectionContact from '../components/sections/SectionContact.astro';
import GeoDivider from '../components/ui/GeoDivider.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
---

<Layout
  title={t.meta.siteTitle}
  description={t.meta.siteDescription}
  ogTitle={t.meta.ogTitle}
  ogDescription={t.meta.ogDescription}
>
  <SchemaOrg slot="schema" />

  <SectionHero />

  <div class="logo-bridge reveal-fade" aria-hidden="true">
    <img src="/images/logo.webp" alt="" width="160" height="160" loading="eager" decoding="async" />
  </div>

  <!-- Bande tags sur fond clair, au-dessus des cartes -->
  <div class="hero-tagband">
    <div class="tagband-inner">
      <a href="https://www.youtube.com/watch?v=kTIPlgRoWUE" target="_blank" rel="noopener noreferrer" class="tagband-link">{t.hero.eyebrowChant}</a>
      <span class="tagband-sep" aria-hidden="true">·</span>
      <a href="https://www.instagram.com/reel/DQhuDa2jATw/?igsh=c2k0OXV1M2JkbXBh" target="_blank" rel="noopener noreferrer" class="tagband-link">{t.hero.eyebrowDanse}</a>
      <span class="tagband-sep" aria-hidden="true">·</span>
      <a href="https://www.instagram.com/band_hay?igsh=cDRxNjVmanEwMWho" target="_blank" rel="noopener noreferrer" class="tagband-link">{t.hero.eyebrowMusique}</a>
      <span class="tagband-sep" aria-hidden="true">·</span>
      <a href={`${lang === 'fr' ? '' : `/${lang}`}/galerie`} class="tagband-link">{t.hero.eyebrowGalerie}</a>
    </div>
  </div>

  <div class="prestations-wrap">
    <SectionPrestations />
  </div>


  <SectionGalerie />


  <SectionVideos />


  <SectionApropos />


  <SectionStats />


  <SectionTemoignages />


  <SectionFAQ />


  <SectionContact />
</Layout>

<style>
  .hero-tagband {
    background-color: var(--color-bg-primary);
    border-bottom: 0.5px solid var(--color-border);
  }

  .tagband-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-block: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tagband-link {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 280ms;
  }

  .tagband-link:hover {
    color: var(--color-accent);
  }

  .tagband-sep {
    color: var(--color-border);
    font-size: 10px;
  }

  .logo-bridge {
    display: flex;
    justify-content: center;
    padding-block: 1.25rem 0.75rem;
    background-color: var(--color-bg-primary);
  }

  .logo-bridge img {
    width: 140px;
    height: auto;
    opacity: 0.9;
  }

  .prestations-wrap :global(.section-prestations) {
    padding-top: 2rem;
  }

  @media (max-width: 768px) {
    .logo-bridge img { width: 110px; }
  }
</style>
