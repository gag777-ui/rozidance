---
const cards = [
  { slug: 'chant-armenien',      title: 'Chant arménien',    desc: 'Répertoire traditionnel transmis avec passion.' },
  { slug: 'chant-jazz-soul-pop', title: 'Jazz · Soul · Pop', desc: 'Voix adaptée à chaque ambiance, de l\'intime au festif.' },
  { slug: 'chant-de-mariage',    title: 'Chant de mariage',  desc: 'Accompagnement vocal sur mesure pour votre plus beau jour.' },
  { slug: 'danse-armenienne',    title: 'Danse arménienne',  desc: 'Chorégraphies traditionnelles pleines de grâce.' },
  { slug: 'danse-en-groupe',     title: 'Danse en groupe',   desc: 'Cours collectifs pour tous niveaux.' },
  { slug: 'cours-en-ligne',      title: 'Cours en ligne',    desc: 'Apprenez depuis chez vous, à votre rythme.' },
];
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Démo — Rozi Dance</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#FAF7F2;--card:#F4EFE6;--dark:#1C1410;
  --acc:#C16847;--gold:#A8882A;--ivory:#FBF8F3;
  --border:rgba(92,74,56,.16);--muted:#9C8470;--sec:#5C4A38;
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --soft:cubic-bezier(.22,1,.36,1);
}
html{scroll-behavior:smooth}
body{
  font-family:var(--sans);
  background:var(--bg);color:var(--dark);
  padding-bottom:8rem;
  -webkit-tap-highlight-color:transparent;
}

/* ─── NAV ─── */
.nav{
  position:sticky;top:0;z-index:999;
  background:rgba(250,247,242,.96);backdrop-filter:blur(14px);
  border-bottom:.5px solid var(--border);
  padding:.6rem 1.25rem;
  display:flex;gap:.4rem;flex-wrap:wrap;align-items:center;
}
.nav em{font-family:var(--serif);font-size:.85rem;color:var(--muted);font-style:italic;margin-right:.5rem;white-space:nowrap}
.nav a{
  font-size:11px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--sec);text-decoration:none;
  padding:.32rem .7rem;border:.5px solid var(--border);border-radius:20px;
  transition:all 170ms;
}
.nav a:hover,.nav a:active{color:var(--acc);border-color:var(--acc);background:rgba(193,104,71,.05)}

/* ─── BLOCS ─── */
.block{padding:4rem 1.25rem 0;max-width:700px;margin:0 auto;scroll-margin-top:3.5rem}
.tag{margin-bottom:2rem;padding-bottom:1rem;border-bottom:.5px solid var(--border)}
.tag-n{font-family:var(--serif);font-size:.75rem;color:var(--acc);letter-spacing:.1em}
.tag-title{font-family:var(--serif);font-size:1.3rem;font-weight:400;color:var(--dark);margin:.2rem 0 .25rem}
.tag-sub{font-size:.72rem;color:var(--muted);letter-spacing:.06em}
.sep{border:none;border-top:.5px solid var(--border);max-width:700px;margin:0 auto}
.col{display:flex;flex-direction:column;gap:1rem}
.col2{display:grid;grid-template-columns:1fr 1fr;gap:.875rem}


/* ══════════════════════════════════════════
   A — TICKET DE SPECTACLE
   Billet avec souche, tirets de découpe
══════════════════════════════════════════ */
.ta{
  display:flex;align-items:stretch;
  background:var(--ivory);
  border-radius:10px;border:.5px solid var(--border);
  overflow:hidden;text-decoration:none;
  transition:transform 300ms var(--soft),box-shadow 300ms var(--soft);
  -webkit-tap-highlight-color:transparent;
}
.ta:active{transform:scale(.98);box-shadow:0 2px 12px rgba(28,20,16,.08)}
.ta:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(28,20,16,.1)}

.ta-stub{
  width:64px;flex-shrink:0;
  background:var(--acc);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;
  padding:.75rem .4rem;
  position:relative;
}
.ta-stub::after{
  content:'';position:absolute;
  top:0;right:-1px;bottom:0;
  border-right:2px dashed rgba(255,255,255,.25);
}
.ta-stub-num{
  font-family:var(--serif);font-size:1.5rem;font-weight:600;color:rgba(255,255,255,.9);line-height:1;
}
.ta-stub-rot{
  font-size:8px;letter-spacing:.18em;text-transform:uppercase;
  color:rgba(255,255,255,.5);
  writing-mode:vertical-rl;transform:rotate(180deg);
}
.ta-hole{
  position:absolute;
  width:16px;height:16px;border-radius:50%;
  background:var(--bg);
  border:.5px solid rgba(255,255,255,.15);
}
.ta-hole-t{top:-8px;right:-8px}
.ta-hole-b{bottom:-8px;right:-8px}

.ta-body{flex:1;padding:1.25rem 1.25rem 1.25rem 1.5rem;display:flex;flex-direction:column;gap:.45rem}
.ta-label{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.ta h3{font-family:var(--serif);font-size:1.2rem;font-weight:400;color:var(--dark);line-height:1.15}
.ta p{font-size:.78rem;color:var(--sec);line-height:1.55}
.ta-row{display:flex;align-items:center;gap:.625rem;margin-top:.25rem}
.ta-tag{font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .5rem;background:rgba(193,104,71,.1);color:var(--acc);border-radius:2px}


/* ══════════════════════════════════════════
   B — STORY / PLEIN ÉCRAN VERTICAL
   Format 9:16, gradient vivant, text en bas
══════════════════════════════════════════ */
.tb-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:.625rem;
}
.tb{
  position:relative;overflow:hidden;
  border-radius:14px;
  aspect-ratio:9/16;
  text-decoration:none;display:block;
  transition:transform 300ms var(--soft);
}
.tb:active{transform:scale(.97)}
.tb:hover{transform:scale(1.02)}

.tb:nth-child(1) .tb-bg{background:linear-gradient(160deg,#2d1510 0%,#C16847 60%,#A8882A 100%)}
.tb:nth-child(2) .tb-bg{background:linear-gradient(160deg,#0e1a10 0%,#2d4a2a 50%,#1a3020 100%)}
.tb:nth-child(3) .tb-bg{background:linear-gradient(160deg,#0a0a18 0%,#1a1535 55%,#C16847 100%)}
.tb:nth-child(4) .tb-bg{background:linear-gradient(160deg,#1a0e08 0%,#3d2010 55%,#C16847 100%)}
.tb:nth-child(5) .tb-bg{background:linear-gradient(160deg,#0d1218 0%,#1c2840 55%,#A8882A 100%)}
.tb:nth-child(6) .tb-bg{background:linear-gradient(160deg,#180810 0%,#3a1525 55%,#C16847 100%)}

.tb-bg{position:absolute;inset:0}
.tb-glow{
  position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 50% at 50% 100%,rgba(0,0,0,.7) 0%,transparent 70%);
}
.tb-body{
  position:absolute;bottom:0;left:0;right:0;
  padding:1rem .875rem;
  display:flex;flex-direction:column;gap:.3rem;
}
.tb-n{font-size:8px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.4)}
.tb h3{font-family:var(--serif);font-size:1rem;font-weight:300;font-style:italic;color:#fff;line-height:1.1}
.tb-arr{
  margin-top:.25rem;
  width:28px;height:28px;border-radius:50%;
  background:rgba(255,255,255,.12);border:.5px solid rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;
  color:#fff;
}


/* ══════════════════════════════════════════
   C — CARTE MINIMALISTE SWISS
   Typographie seule, grille stricte, espace
══════════════════════════════════════════ */
.tc{
  background:var(--card);
  border-radius:0;
  border-left:3px solid transparent;
  padding:1.5rem 1.5rem 1.5rem 1.75rem;
  text-decoration:none;display:grid;
  grid-template-columns:auto 1fr;
  grid-template-rows:auto auto;
  gap:.25rem 1.25rem;
  align-items:start;
  transition:border-left-color 250ms,background 250ms;
  position:relative;
}
.tc::after{
  content:'';position:absolute;
  bottom:0;left:0;right:0;height:.5px;
  background:var(--border);
}
.tc:active,.tc:hover{
  border-left-color:var(--acc);
  background:rgba(193,104,71,.04);
}
.tc-n{
  font-family:var(--serif);font-size:2.5rem;font-weight:300;
  color:var(--border);line-height:1;
  grid-row:1/3;align-self:center;
  transition:color 250ms;
  user-select:none;
}
.tc:hover .tc-n,.tc:active .tc-n{color:rgba(193,104,71,.2)}
.tc h3{font-family:var(--serif);font-size:1.15rem;font-weight:400;color:var(--dark);line-height:1.2;align-self:end}
.tc p{font-size:.78rem;color:var(--sec);line-height:1.55;align-self:start}
.tc-arrow{
  position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);
  color:var(--border);transition:color 250ms,transform 250ms;
}
.tc:hover .tc-arrow,.tc:active .tc-arrow{color:var(--acc);transform:translateY(-50%) translateX(3px)}


/* ══════════════════════════════════════════
   D — CARTE ACCORDÉON
   Se déplie sur tap, contenu caché au départ
   (utilise :focus-within pour mobile)
══════════════════════════════════════════ */
.td{
  background:var(--dark);border-radius:12px;
  overflow:hidden;
  text-decoration:none;display:block;
  position:relative;
}
.td-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.25rem 1.5rem;gap:1rem;
  cursor:pointer;
}
.td-left{display:flex;align-items:center;gap:1rem}
.td-num{
  font-family:var(--serif);font-size:1.75rem;font-weight:300;
  color:var(--acc);line-height:1;flex-shrink:0;
}
.td h3{font-family:var(--serif);font-size:1.1rem;font-weight:300;font-style:italic;color:#fff;line-height:1.2}
.td-plus{
  width:32px;height:32px;border-radius:50%;
  border:.5px solid rgba(255,255,255,.15);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  color:rgba(255,255,255,.5);
  font-size:1.1rem;line-height:1;
  transition:transform 350ms var(--soft),background 300ms,color 300ms;
}
.td-body{
  max-height:0;overflow:hidden;
  transition:max-height 400ms var(--soft);
  padding:0 1.5rem;
}
.td p{font-size:.8rem;color:rgba(255,255,255,.4);line-height:1.65;padding-bottom:1.25rem}
.td-tag{
  display:inline-block;font-size:9px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--acc);border:.5px solid rgba(193,104,71,.4);
  padding:.2rem .55rem;border-radius:2px;margin-bottom:.875rem;
}
/* ouverture au hover sur desktop, :active sur mobile */
.td:hover .td-body,
.td:focus-within .td-body,
.td.open .td-body{max-height:200px}
.td:hover .td-plus,
.td:focus-within .td-plus,
.td.open .td-plus{transform:rotate(45deg);background:var(--acc);border-color:var(--acc);color:#fff}
.td:active .td-body{max-height:200px}
.td:active .td-plus{transform:rotate(45deg);background:var(--acc);border-color:var(--acc);color:#fff}
.td-line{height:.5px;background:rgba(255,255,255,.06);margin:0 1.5rem}


/* ══════════════════════════════════════════
   E — TUILE MAGAZINE MOSAÏQUE
   Grille brisée, 3 tailles différentes
   Chaque tuile a sa couleur et sa typo
══════════════════════════════════════════ */
.te-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:auto;
  gap:.625rem;
}
.te{
  border-radius:12px;overflow:hidden;
  text-decoration:none;display:flex;flex-direction:column;
  justify-content:flex-end;padding:1.25rem;
  min-height:140px;
  position:relative;
  transition:transform 300ms var(--soft);
}
.te:active{transform:scale(.97)}
.te:hover{transform:scale(1.02)}

/* tailles */
.te:nth-child(1){grid-column:1/3;min-height:180px}
.te:nth-child(4){grid-column:1/3;min-height:160px}

/* couleurs */
.te:nth-child(1){background:var(--dark)}
.te:nth-child(2){background:#2a1a0e}
.te:nth-child(3){background:var(--acc)}
.te:nth-child(4){background:#f0e8da;border:.5px solid var(--border)}
.te:nth-child(5){background:#1a1020}
.te:nth-child(6){background:var(--gold)}

.te-n{
  font-family:var(--serif);font-size:.7rem;letter-spacing:.14em;
  margin-bottom:.35rem;opacity:.5;
}
.te:nth-child(4) .te-n{color:var(--sec)}
.te:not(:nth-child(4)) .te-n{color:#fff}

.te h3{
  font-family:var(--serif);font-size:clamp(.95rem,2.5vw,1.25rem);
  font-weight:400;line-height:1.15;
}
.te:nth-child(4) h3{color:var(--dark);font-style:italic}
.te:not(:nth-child(4)) h3{color:#fff;font-weight:300;font-style:italic}

.te p{
  font-size:.72rem;line-height:1.5;margin-top:.3rem;
}
.te:nth-child(4) p{color:var(--sec)}
.te:not(:nth-child(4)) p{color:rgba(255,255,255,.5)}

/* ornement coin */
.te::before{
  content:'';position:absolute;top:.875rem;right:.875rem;
  width:8px;height:8px;border-radius:50%;
  transition:transform 300ms;
}
.te:nth-child(1)::before{background:var(--acc)}
.te:nth-child(2)::before{background:var(--gold)}
.te:nth-child(3)::before{background:rgba(255,255,255,.5)}
.te:nth-child(4)::before{background:var(--gold)}
.te:nth-child(5)::before{background:var(--acc)}
.te:nth-child(6)::before{background:rgba(255,255,255,.5)}
.te:hover::before,.te:active::before{transform:scale(1.6)}

@media(min-width:640px){
  .block{padding:4rem 2rem 0}
  .tb-grid{grid-template-columns:repeat(6,1fr)}
  .tc-n{font-size:3rem}
  .te:nth-child(1){min-height:220px}
}
</style>
</head>
<body>

<nav class="nav">
  <em>Rozi Dance</em>
  <a href="#sa">A</a>
  <a href="#sb">B</a>
  <a href="#sc">C</a>
  <a href="#sd">D</a>
  <a href="#se">E</a>
</nav>


<!-- A — TICKET -->
<div class="block" id="sa">
  <div class="tag">
    <div class="tag-n">Design A</div>
    <div class="tag-title">Ticket de spectacle</div>
    <div class="tag-sub">Souche colorée · tirets de découpe · format billet</div>
  </div>
  <div class="col">
    {cards.map((c,i)=>(
      <a href="#" class="ta">
        <div class="ta-stub">
          <div class="ta-hole ta-hole-t"></div>
          <div class="ta-hole ta-hole-b"></div>
          <span class="ta-stub-num">{String(i+1).padStart(2,'0')}</span>
          <span class="ta-stub-rot">Rozi Dance</span>
        </div>
        <div class="ta-body">
          <span class="ta-label">Cours — Belgique</span>
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
          <div class="ta-row">
            <span class="ta-tag">Réserver</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>
<hr class="sep"/>


<!-- B — STORY -->
<div class="block" id="sb">
  <div class="tag">
    <div class="tag-n">Design B</div>
    <div class="tag-title">Format story vertical</div>
    <div class="tag-sub">9:16 · gradient vivant · natif mobile</div>
  </div>
  <div class="tb-grid">
    {cards.map((c,i)=>(
      <a href="#" class="tb">
        <div class="tb-bg"></div>
        <div class="tb-glow"></div>
        <div class="tb-body">
          <span class="tb-n">0{i+1}</span>
          <h3>{c.title}</h3>
          <div class="tb-arr">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>
<hr class="sep"/>


<!-- C — SWISS -->
<div class="block" id="sc">
  <div class="tag">
    <div class="tag-n">Design C</div>
    <div class="tag-title">Typographie Swiss minimaliste</div>
    <div class="tag-sub">Grand numéro · liste épurée · bordure gauche au tap</div>
  </div>
  <div style="border-top:.5px solid var(--border)">
    {cards.map((c,i)=>(
      <a href="#" class="tc">
        <span class="tc-n">{String(i+1).padStart(2,'0')}</span>
        <h3>{c.title}</h3>
        <p>{c.desc}</p>
        <svg class="tc-arrow" width="16" height="16" viewBox="0 0 14 14" fill="none">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    ))}
  </div>
</div>
<hr class="sep"/>


<!-- D — ACCORDÉON -->
<div class="block" id="sd">
  <div class="tag">
    <div class="tag-n">Design D</div>
    <div class="tag-title">Accordéon dépliable</div>
    <div class="tag-sub">Fond sombre · description cachée · se déploie au tap</div>
  </div>
  <div class="col">
    {cards.map((c,i)=>(
      <div class="td">
        {i > 0 && <div class="td-line"></div>}
        <div class="td-head">
          <div class="td-left">
            <span class="td-num">{String(i+1).padStart(2,'0')}</span>
            <h3>{c.title}</h3>
          </div>
          <div class="td-plus">+</div>
        </div>
        <div class="td-body">
          <span class="td-tag">Cours</span>
          <p>{c.desc}</p>
        </div>
      </div>
    ))}
  </div>
</div>
<hr class="sep"/>


<!-- E — MOSAÏQUE -->
<div class="block" id="se">
  <div class="tag">
    <div class="tag-n">Design E</div>
    <div class="tag-title">Mosaïque magazine</div>
    <div class="tag-sub">Grille brisée · 3 fonds · tailles variées</div>
  </div>
  <div class="te-grid">
    {cards.map((c,i)=>(
      <a href="#" class="te">
        <span class="te-n">0{i+1} — Rozi Dance</span>
        <h3>{c.title}</h3>
        <p>{c.desc}</p>
      </a>
    ))}
  </div>
</div>

</body>
</html>
