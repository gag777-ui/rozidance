---
const cards = [
  { slug: 'chant-armenien',      title: 'Chant arménien',    init:'C', desc: 'Répertoire traditionnel transmis avec passion et mémoire.' },
  { slug: 'chant-jazz-soul-pop', title: 'Jazz · Soul · Pop', init:'J', desc: 'Voix adaptée à chaque ambiance, de l\'intime au festif.' },
  { slug: 'chant-de-mariage',    title: 'Chant de mariage',  init:'M', desc: 'Accompagnement vocal sur mesure pour votre plus beau jour.' },
  { slug: 'danse-armenienne',    title: 'Danse arménienne',  init:'D', desc: 'Chorégraphies traditionnelles pleines de grâce et d\'énergie.' },
  { slug: 'danse-en-groupe',     title: 'Danse en groupe',   init:'G', desc: 'Cours collectifs pour tous niveaux dans une atmosphère chaleureuse.' },
  { slug: 'cours-en-ligne',      title: 'Cours en ligne',    init:'L', desc: 'Apprenez depuis chez vous, à votre rythme, en visioconférence.' },
];
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Démo — Rozi Dance</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#FAF7F2;--card:#F4EFE6;--dark:#1C1410;
  --acc:#C16847;--gold:#A8882A;--ivory:#FBF8F3;
  --border:rgba(92,74,56,.16);--muted:#9C8470;--sec:#5C4A38;
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --soft:cubic-bezier(.22,1,.36,1);
}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--bg);color:var(--dark);padding-bottom:10rem;overflow-x:hidden}

.nav{
  position:sticky;top:0;z-index:999;
  background:rgba(250,247,242,.94);backdrop-filter:blur(14px);
  border-bottom:.5px solid var(--border);
  padding:.6rem 2rem;display:flex;gap:.4rem;flex-wrap:wrap;align-items:center;
}
.nav em{font-family:var(--serif);font-size:.85rem;color:var(--muted);font-style:italic;margin-right:.75rem}
.nav a{
  font-size:10px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--sec);text-decoration:none;
  padding:.28rem .65rem;border:.5px solid var(--border);border-radius:2px;
  transition:all 170ms;
}
.nav a:hover{color:var(--acc);border-color:var(--acc)}

.block{padding:5rem 2rem 0;max-width:1180px;margin:0 auto;scroll-margin-top:3.5rem}
.tag{
  display:flex;align-items:flex-end;gap:1rem;margin-bottom:2.5rem;
  border-left:2px solid var(--acc);padding-left:1.25rem;
}
.tag-n{font-family:var(--serif);font-size:4.5rem;font-weight:300;line-height:.85;color:var(--acc);opacity:.2}
.tag-info{display:flex;flex-direction:column;gap:.2rem}
.tag-title{font-family:var(--serif);font-size:1.4rem;font-weight:400;color:var(--dark)}
.tag-sub{font-size:.75rem;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}

.sep{border:none;border-top:.5px solid var(--border);max-width:1180px;margin:0 auto}
.g3{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem}
.g2{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:1.25rem}


/* ══════════════════════════════════════════
   01 — LA FLAMME
   Feu qui monte dans le fond, asymétrie forte
══════════════════════════════════════════ */
.f1{
  position:relative;overflow:hidden;border-radius:16px;
  background:#120a06;
  padding:0;text-decoration:none;display:block;
  aspect-ratio:3/4;
  transition:transform 500ms var(--soft);
}
.f1:hover{transform:scale(1.02)}
.f1-fire{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 30% 110%,rgba(193,104,71,.9) 0%,rgba(168,136,42,.4) 35%,transparent 65%),
    radial-gradient(ellipse 50% 40% at 70% 120%,rgba(193,104,71,.5) 0%,transparent 55%);
  animation:fire 3s ease-in-out infinite alternate;
  transform-origin:bottom center;
}
@keyframes fire{
  0%{transform:scaleX(1) skewX(0deg);opacity:.8}
  33%{transform:scaleX(1.05) skewX(-2deg);opacity:1}
  66%{transform:scaleX(.97) skewX(1.5deg);opacity:.85}
  100%{transform:scaleX(1.03) skewX(-1deg);opacity:.9}
}
.f1:hover .f1-fire{animation-duration:1.2s}
.f1-num{
  position:absolute;top:1.25rem;right:1.25rem;
  font-family:var(--serif);font-size:5rem;font-weight:300;line-height:1;
  color:rgba(255,255,255,.06);user-select:none;
}
.f1-body{
  position:absolute;bottom:0;left:0;right:0;
  padding:2rem 1.75rem 1.75rem;
  background:linear-gradient(to top,rgba(12,7,4,.95) 0%,rgba(12,7,4,.6) 60%,transparent 100%);
  display:flex;flex-direction:column;gap:.5rem;
}
.f1-eye{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgba(193,104,71,.7)}
.f1 h3{font-family:var(--serif);font-size:1.5rem;font-weight:300;font-style:italic;color:#fff;line-height:1.1}
.f1 p{font-size:.75rem;color:rgba(255,255,255,.4);line-height:1.6}


/* ══════════════════════════════════════════
   02 — COUTURE OBLIQUE
   Diagonale décalée, deux univers dans une carte
══════════════════════════════════════════ */
.f2{
  position:relative;overflow:hidden;border-radius:12px;
  background:var(--ivory);border:.5px solid var(--border);
  min-height:220px;text-decoration:none;display:flex;
  transition:box-shadow 400ms var(--soft),transform 400ms var(--soft);
}
.f2:hover{box-shadow:0 20px 60px rgba(28,20,16,.12);transform:translateY(-5px)}
.f2-dark{
  position:absolute;
  top:0;right:0;bottom:0;
  width:42%;
  background:var(--dark);
  clip-path:polygon(25% 0%,100% 0%,100% 100%,0% 100%);
  transition:width 450ms var(--soft),clip-path 450ms var(--soft);
}
.f2:hover .f2-dark{width:48%;clip-path:polygon(20% 0%,100% 0%,100% 100%,0% 100%)}
.f2-body{position:relative;z-index:1;padding:1.75rem;display:flex;flex-direction:column;gap:.625rem;flex:1;max-width:68%}
.f2-n{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.f2 h3{font-family:var(--serif);font-size:1.3rem;font-weight:400;color:var(--dark);line-height:1.2}
.f2 p{font-size:.8rem;color:var(--sec);line-height:1.6}
.f2-badge{
  position:absolute;z-index:2;
  top:50%;right:calc(42% - 22px);
  transform:translateY(-50%);
  width:44px;height:44px;border-radius:50%;
  background:var(--acc);
  display:flex;align-items:center;justify-content:center;
  color:#fff;
  box-shadow:0 4px 20px rgba(193,104,71,.4);
  transition:right 450ms var(--soft),transform 450ms var(--soft);
}
.f2:hover .f2-badge{right:calc(48% - 22px)}


/* ══════════════════════════════════════════
   03 — INITIALE MONUMENTALE
   La première lettre déborde, très éditorial
══════════════════════════════════════════ */
.f3-wrap{display:flex;flex-direction:column;gap:0}
.f3{
  position:relative;
  padding:1.75rem 1.75rem 1.75rem 5.5rem;
  border-bottom:.5px solid var(--border);
  text-decoration:none;display:block;
  overflow:visible;
  transition:background 300ms;
}
.f3:hover{background:rgba(193,104,71,.03)}
.f3-init{
  position:absolute;
  left:-.25rem;top:50%;transform:translateY(-50%);
  font-family:var(--serif);font-size:6.5rem;font-weight:600;
  color:var(--border);line-height:1;
  pointer-events:none;user-select:none;
  transition:color 350ms,transform 350ms var(--soft);
}
.f3:hover .f3-init{color:rgba(193,104,71,.12);transform:translateY(-50%) scale(1.08)}
.f3-n{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--acc);margin-bottom:.35rem}
.f3 h3{font-family:var(--serif);font-size:1.5rem;font-weight:300;font-style:italic;color:var(--dark);line-height:1.1;margin-bottom:.5rem}
.f3 p{font-size:.82rem;color:var(--sec);line-height:1.6;max-width:55ch}
.f3-arr{
  position:absolute;right:1.75rem;top:50%;transform:translateY(-50%);
  width:36px;height:36px;border-radius:50%;border:.5px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  color:var(--muted);
  transition:all 300ms var(--soft);opacity:0;
}
.f3:hover .f3-arr{opacity:1;background:var(--acc);border-color:var(--acc);color:#fff;transform:translateY(-50%) rotate(-45deg)}


/* ══════════════════════════════════════════
   04 — INVITATION DORÉE
   Style carton d'invitation haut de gamme
══════════════════════════════════════════ */
.f4{
  background:var(--ivory);
  border:1px solid rgba(168,136,42,.25);
  border-radius:4px;
  padding:2.5rem 2rem;
  text-decoration:none;
  display:flex;flex-direction:column;
  align-items:flex-start;
  gap:.875rem;
  position:relative;overflow:hidden;
  transition:box-shadow 400ms var(--soft),transform 400ms var(--soft);
}
.f4::before,.f4::after{
  content:'';position:absolute;
  width:40px;height:40px;
}
.f4::before{top:12px;left:12px;border-top:1px solid rgba(168,136,42,.4);border-left:1px solid rgba(168,136,42,.4)}
.f4::after{bottom:12px;right:12px;border-bottom:1px solid rgba(168,136,42,.4);border-right:1px solid rgba(168,136,42,.4)}
.f4-shimmer{
  position:absolute;inset:0;
  background:linear-gradient(105deg,transparent 40%,rgba(168,136,42,.08) 50%,transparent 60%);
  transform:translateX(-100%);
  transition:transform 600ms var(--soft);
}
.f4:hover .f4-shimmer{transform:translateX(100%)}
.f4:hover{box-shadow:0 16px 48px rgba(168,136,42,.12);transform:translateY(-4px)}
.f4-orn{width:24px;height:1px;background:linear-gradient(to right,var(--gold),rgba(168,136,42,.3))}
.f4-eye{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)}
.f4 h3{font-family:var(--serif);font-size:1.35rem;font-weight:400;font-style:italic;color:var(--dark);line-height:1.2}
.f4 p{font-size:.8rem;color:var(--sec);line-height:1.7;font-style:italic}
.f4-cta{
  margin-top:.25rem;font-size:9px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--gold);display:flex;align-items:center;gap:.5rem;
  transition:gap 250ms;
}
.f4:hover .f4-cta{gap:.8rem}


/* ══════════════════════════════════════════
   05 — SCÈNE & RIDEAU
   Rideau qui se lève, révèle le fond sombre
══════════════════════════════════════════ */
.f5{
  position:relative;overflow:hidden;border-radius:10px;
  background:var(--dark);
  min-height:240px;text-decoration:none;
  display:flex;flex-direction:column;justify-content:flex-end;
  transition:transform 400ms var(--soft);
}
.f5:hover{transform:translateY(-5px)}
.f5-curtain{
  position:absolute;inset:0;
  background:var(--card);
  transform-origin:top center;
  transition:transform 600ms var(--soft);
  border-radius:10px;
}
.f5:hover .f5-curtain{transform:scaleY(0)}
.f5-front{
  position:absolute;inset:0;padding:1.75rem;
  display:flex;flex-direction:column;justify-content:flex-end;gap:.5rem;
  z-index:1;
}
.f5-n{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.3)}
.f5 h3{font-family:var(--serif);font-size:1.4rem;font-weight:300;font-style:italic;color:#fff;line-height:1.1}
.f5 p{font-size:.78rem;color:rgba(255,255,255,.45);line-height:1.6}
.f5-curtain-text{
  position:absolute;inset:0;
  display:flex;flex-direction:column;justify-content:center;align-items:flex-start;
  padding:1.75rem;gap:.5rem;
  transition:opacity 200ms;
}
.f5:hover .f5-curtain-text{opacity:0}
.f5-ct-n{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--acc)}
.f5-ct h3{font-family:var(--serif);font-size:1.35rem;font-weight:400;color:var(--dark);line-height:1.2}
.f5-ct p{font-size:.8rem;color:var(--sec);line-height:1.6}


/* ══════════════════════════════════════════
   06 — NÉGATIF PHOTOGRAPHIQUE
   La carte s'inverse comme un négatif photo
══════════════════════════════════════════ */
.f6{
  background:var(--dark);border-radius:8px;
  padding:2rem 1.75rem;text-decoration:none;
  display:flex;flex-direction:column;gap:.75rem;
  position:relative;overflow:hidden;
  transition:transform 400ms var(--soft);
}
.f6::before{
  content:'';position:absolute;inset:0;
  background:var(--ivory);
  opacity:0;
  transition:opacity 400ms;
  z-index:0;
}
.f6:hover::before{opacity:1}
.f6:hover{transform:scale(1.02)}
.f6>*{position:relative;z-index:1;transition:color 400ms}
.f6-n{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.3)}
.f6:hover .f6-n{color:var(--muted)}
.f6 h3{font-family:var(--serif);font-size:1.4rem;font-weight:300;font-style:italic;color:#fff;line-height:1.15}
.f6:hover h3{color:var(--dark)}
.f6 p{font-size:.8rem;color:rgba(255,255,255,.4);line-height:1.65;flex:1}
.f6:hover p{color:var(--sec)}
.f6-line{height:1px;background:rgba(255,255,255,.15);transition:background 400ms}
.f6:hover .f6-line{background:var(--border)}
.f6-link{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--acc)}


/* ══════════════════════════════════════════
   07 — PLAN CINÉMATOGRAPHIQUE
   Pellicule, scan-line, feeling cinéma arménien
══════════════════════════════════════════ */
.f7{
  background:#0a0604;
  border-radius:0;padding:0;text-decoration:none;
  display:flex;overflow:hidden;
  position:relative;
  transition:transform 400ms var(--soft);
}
.f7:hover{transform:scale(1.015)}
.f7-film{
  width:28px;flex-shrink:0;
  background:repeating-linear-gradient(
    to bottom,
    #111 0px,#111 8px,
    transparent 8px,transparent 12px
  );
  border-right:1px solid rgba(255,255,255,.06);
}
.f7-scan{
  position:absolute;inset:0;
  background:linear-gradient(to bottom,transparent 0%,rgba(255,255,255,.04) 50%,transparent 100%);
  height:30%;width:100%;
  animation:scan 4s linear infinite;
  pointer-events:none;
}
@keyframes scan{0%{top:-30%}100%{top:130%}}
.f7-body{flex:1;padding:1.75rem 1.5rem;display:flex;flex-direction:column;gap:.625rem}
.f7-meta{font-family:monospace;font-size:9px;letter-spacing:.1em;color:rgba(255,255,255,.2)}
.f7 h3{font-family:var(--serif);font-size:1.3rem;font-weight:300;font-style:italic;color:rgba(255,255,255,.88);line-height:1.15}
.f7 p{font-size:.75rem;color:rgba(255,255,255,.3);line-height:1.65;flex:1}
.f7-tc{font-family:monospace;font-size:8px;color:rgba(193,104,71,.5);margin-top:.25rem}


/* ══════════════════════════════════════════
   08 — ARABESQUE ORNÉE
   Inspiré de l'art décoratif arménien
══════════════════════════════════════════ */
.f8{
  background:var(--ivory);
  border-radius:12px;border:.5px solid var(--border);
  padding:2.25rem 1.75rem 1.75rem 1.75rem;
  text-decoration:none;display:flex;flex-direction:column;gap:.875rem;
  position:relative;overflow:hidden;
  transition:transform 400ms var(--soft),box-shadow 400ms var(--soft);
}
.f8:hover{transform:translateY(-5px);box-shadow:0 24px 60px rgba(168,136,42,.1)}
.f8-orn{
  position:absolute;top:0;right:0;
  width:80px;height:80px;
  opacity:.07;
  transition:opacity 400ms,transform 500ms var(--soft);
}
.f8:hover .f8-orn{opacity:.14;transform:scale(1.1) rotate(10deg)}
.f8-rule{
  height:.5px;width:100%;
  background:linear-gradient(to right,var(--gold),var(--acc),transparent);
  margin-bottom:.25rem;
}
.f8-n{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.f8 h3{font-family:var(--serif);font-size:1.35rem;font-weight:400;font-style:italic;color:var(--dark);line-height:1.2}
.f8 p{font-size:.82rem;color:var(--sec);line-height:1.68}
.f8-footer{display:flex;align-items:center;gap:.75rem;margin-top:.25rem}
.f8-dot{width:4px;height:4px;border-radius:50%;background:var(--gold)}
.f8-link{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);transition:letter-spacing 250ms}
.f8:hover .f8-link{letter-spacing:.22em}


/* ══════════════════════════════════════════
   09 — OMBRE DRAMATIQUE
   La carte est poussée dans la page, ombre massive
══════════════════════════════════════════ */
.f9{
  background:#fff;border-radius:6px;
  border:.5px solid var(--border);
  padding:2rem 1.75rem;
  text-decoration:none;display:flex;flex-direction:column;gap:.75rem;
  position:relative;
  box-shadow:
    3px 3px 0 rgba(193,104,71,.1),
    6px 6px 0 rgba(193,104,71,.06),
    9px 9px 0 rgba(193,104,71,.03);
  transition:transform 400ms var(--soft),box-shadow 400ms var(--soft);
}
.f9:hover{
  transform:translate(-5px,-5px);
  box-shadow:
    8px 8px 0 rgba(193,104,71,.18),
    16px 16px 0 rgba(193,104,71,.1),
    24px 24px 0 rgba(193,104,71,.05);
}
.f9-n{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--acc)}
.f9 h3{font-family:var(--serif);font-size:1.35rem;font-weight:400;color:var(--dark);line-height:1.2}
.f9 p{font-size:.82rem;color:var(--sec);line-height:1.65;flex:1}
.f9-bar{
  height:2px;width:32px;
  background:var(--acc);
  transition:width 400ms var(--soft);
}
.f9:hover .f9-bar{width:100%}


/* ══════════════════════════════════════════
   10 — TEXTE QUI RESPIRE
   Layout presque sans cadre, typo seule, espace négatif
══════════════════════════════════════════ */
.f10-grid{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  grid-template-rows:auto;
  gap:0;
}
.f10{
  padding:2.5rem 2rem;
  border:.25px solid var(--border);
  text-decoration:none;display:flex;flex-direction:column;gap:.625rem;
  position:relative;overflow:hidden;
  transition:background 300ms;
}
.f10:nth-child(1){grid-column:1/3;border-bottom:none}
.f10:nth-child(2){grid-column:3;background:var(--dark)}
.f10:nth-child(3){grid-column:1}
.f10:nth-child(4){grid-column:2/4;background:var(--acc)}
.f10:nth-child(5){grid-column:1/2}
.f10:nth-child(6){grid-column:2/4}
.f10::after{
  content:'';position:absolute;
  inset:0;background:rgba(193,104,71,.04);
  opacity:0;transition:opacity 250ms;
}
.f10:nth-child(2)::after,.f10:nth-child(4)::after{background:rgba(255,255,255,.06)}
.f10:hover::after{opacity:1}
.f10-n{font-size:8px;letter-spacing:.22em;text-transform:uppercase;color:var(--acc);position:relative;z-index:1}
.f10:nth-child(2) .f10-n{color:rgba(255,255,255,.3)}
.f10:nth-child(4) .f10-n{color:rgba(255,255,255,.5)}
.f10 h3{font-family:var(--serif);font-size:clamp(1.1rem,2vw,1.5rem);font-weight:400;font-style:italic;color:var(--dark);line-height:1.15;position:relative;z-index:1}
.f10:nth-child(2) h3,.f10:nth-child(4) h3{color:#fff}
.f10 p{font-size:.78rem;color:var(--sec);line-height:1.65;position:relative;z-index:1}
.f10:nth-child(2) p{color:rgba(255,255,255,.4)}
.f10:nth-child(4) p{color:rgba(255,255,255,.65)}

@media(max-width:700px){
  .f10-grid{grid-template-columns:1fr}
  .f10:nth-child(n){grid-column:1}
  .f3{padding-left:4.5rem}
  .f3-init{font-size:4.5rem}
}
</style>
</head>
<body>

<nav class="nav">
  <em>Rozi Dance</em>
  <a href="#s01">01</a><a href="#s02">02</a><a href="#s03">03</a>
  <a href="#s04">04</a><a href="#s05">05</a><a href="#s06">06</a>
  <a href="#s07">07</a><a href="#s08">08</a><a href="#s09">09</a>
  <a href="#s10">10</a>
</nav>


<!-- 01 ─ FLAMME -->
<div class="block" id="s01">
  <div class="tag"><span class="tag-n">01</span><div class="tag-info"><div class="tag-title">La flamme — feu animé en fond</div><div class="tag-sub">Gradient qui brûle, title en bas à gauche</div></div></div>
  <div class="g3">
    {cards.map((c,i)=>(
      <a href="#" class="f1">
        <div class="f1-fire"></div>
