---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
const base = lang === 'fr' ? '' : `/${lang}`;
---

<header id="site-header" class="site-header">
  <div class="section-container header-inner">
    <!-- Logo -->
    <a href={base || '/'} class="logo" aria-label="Rozi Dance — accueil">
      <img
        src="/images/logo.webp"
        alt=""
        class="logo-img"
        width="76"
        height="76"
        loading="eager"
        decoding="async"
      />
      <span class="logo-text">Rozi <span class="logo-dot">·</span> Dance</span>
    </a>

    <!-- Nav desktop -->
    <nav class="nav-desktop" aria-label="Navigation principale">
      <ul>
        <li><a href={`${base || '/'}#prestations`} class="nav-link">{t.nav.prestations}</a></li>
        <li><a href={`${base || '/'}#galerie`} class="nav-link">{t.nav.galerie}</a></li>
        <li><a href={`${base}/cours`} class="nav-link">{t.nav.cours}</a></li>
        <li><a href={`${base || '/'}#apropos`} class="nav-link">{t.nav.apropos}</a></li>
        <li><a href={`${base || '/'}#contact`} class="nav-link">{t.nav.contact}</a></li>
      </ul>
    </nav>

    <!-- CTA desktop -->
    <a href={`${base || '/'}#contact`} class="btn-primary header-cta">
      {t.nav.contact}
    </a>

    <!-- Sélecteur de langue + hamburger groupés -->
    <div class="header-end">
      <LanguageSwitcher />
      <button
        id="menu-toggle"
        class="menu-toggle"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<!-- Overlay menu mobile (hors du header pour z-index indépendant) -->
<nav id="mobile-menu" class="nav-mobile" aria-label="Menu mobile" aria-hidden="true">
  <div class="mobile-menu-inner">
    <ul>
      <li><a href={`${base || '/'}#prestations`} class="mobile-nav-link">{t.nav.prestations}</a></li>
      <li><a href={`${base || '/'}#galerie`} class="mobile-nav-link">{t.nav.galerie}</a></li>
      <li><a href={`${base}/cours`} class="mobile-nav-link">{t.nav.cours}</a></li>
      <li><a href={`${base || '/'}#apropos`} class="mobile-nav-link">{t.nav.apropos}</a></li>
      <li><a href={`${base || '/'}#contact`} class="mobile-nav-link">{t.nav.contact}</a></li>
    </ul>

    <div class="mobile-menu-footer">
      <span class="mobile-menu-sig">Rozi <span class="mobile-menu-dot">·</span> Dance</span>
    </div>
  </div>
</nav>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 150;
    background-color: var(--color-bg-primary);
    border-bottom: 0.5px solid transparent;
    transition: border-color 300ms, backdrop-filter 300ms, background-color 300ms;
  }

  .site-header.scrolled {
    border-color: var(--color-border);
    backdrop-filter: blur(12px);
    background-color: rgba(247, 241, 230, 0.85);
  }

  /* Header ivoire quand le menu est ouvert */
  .site-header.menu-open {
    background-color: var(--color-bg-primary);
    border-bottom-color: transparent;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .logo-img {
    display: block;
    width: 76px;
    height: 76px;
    object-fit: contain;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
  }

  .logo-dot {
    color: var(--color-accent);
  }

  .nav-desktop ul {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-cta {
    flex-shrink: 0;
    padding: 0.5rem 1.25rem;
  }

  .header-end {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Hamburger ── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 1;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-text-primary);
    transition: transform 350ms var(--ease-out-soft), opacity 250ms, width 350ms var(--ease-out-soft);
    transform-origin: center;
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Overlay menu mobile ── */
  .nav-mobile {
    position: fixed;
    inset: 0;
    z-index: 140;
    background-color: var(--color-bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;

    /* Fermé */
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms var(--ease-out-soft);
  }

  .nav-mobile.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    width: 100%;
    padding: 2rem;
  }

  .nav-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 7vw, 2.75rem);
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    letter-spacing: 0.01em;
    display: block;
    padding: 0.5rem 1.5rem;
    transition: color 250ms;

    /* Entrée animée — état initial */
    opacity: 0;
    transform: translateY(20px);
    transition: color 250ms, opacity 500ms var(--ease-out-soft), transform 500ms var(--ease-out-soft);
  }

  .nav-mobile.is-open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger par ordre de li */
  .nav-mobile.is-open li:nth-child(1) .mobile-nav-link { transition-delay: 60ms; }
  .nav-mobile.is-open li:nth-child(2) .mobile-nav-link { transition-delay: 120ms; }
  .nav-mobile.is-open li:nth-child(3) .mobile-nav-link { transition-delay: 180ms; }
  .nav-mobile.is-open li:nth-child(4) .mobile-nav-link { transition-delay: 240ms; }
  .nav-mobile.is-open li:nth-child(5) .mobile-nav-link { transition-delay: 300ms; }

  .mobile-nav-link:hover { color: #fff; }
  .mobile-nav-link:active { color: var(--color-accent); }

  /* Signature en bas */
  .mobile-menu-footer {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 500ms var(--ease-out-soft) 360ms, transform 500ms var(--ease-out-soft) 360ms;
  }

  .nav-mobile.is-open .mobile-menu-footer {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu-sig {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.06em;
  }

  .mobile-menu-dot {
    color: var(--color-accent);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .nav-desktop,
    .header-cta {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }
  }

  /* Sur desktop : jamais d'overlay */
  @media (min-width: 769px) {
    .nav-mobile {
      display: none !important;
    }
  }
</style>

<script>
  let headerScrollHandler: (() => void) | null = null;

  function initHeader() {
    if (headerScrollHandler) {
      window.removeEventListener('scroll', headerScrollHandler);
    }

    const header = document.getElementById('site-header');
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    headerScrollHandler = () => {
      header?.classList.toggle('scrolled', window.scrollY > 40);
    };
    window.addEventListener('scroll', headerScrollHandler, { passive: true });
    headerScrollHandler();

    function openMenu() {
      mobileMenu?.classList.add('is-open');
      mobileMenu?.setAttribute('aria-hidden', 'false');
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Fermer le menu');
      header?.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      mobileMenu?.classList.remove('is-open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Ouvrir le menu');
      header?.classList.remove('menu-open');
      document.body.style.overflow = '';
    }

    toggle?.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    mobileMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Ferme au swipe vers le haut (UX mobile)
    let touchStartY = 0;
    mobileMenu?.addEventListener('touchstart', (e) => {
      touchStartY = e.touches[0].clientY;
    }, { passive: true });
    mobileMenu?.addEventListener('touchend', (e) => {
      if (touchStartY - e.changedTouches[0].clientY > 60) closeMenu();
    }, { passive: true });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
