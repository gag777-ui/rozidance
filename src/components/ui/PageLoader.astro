---
---

<div id="page-loader" role="status" aria-label="Chargement">
  <div class="loader-logo">
    <img
      src="/images/logo.webp"
      alt="Rozi Dance"
      class="loader-logo-img"
      width="64"
      height="64"
    />
    <span class="loader-logo-text">Rozi <span class="loader-dot">·</span> Dance</span>
  </div>
</div>

<style>
  .loader-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: loaderFadeIn 500ms var(--ease-out-soft) both;
  }

  .loader-logo-img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    display: block;
    animation: loaderPulse 1600ms ease-in-out 0ms infinite;
  }

  .loader-logo-text {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: 0.04em;
    display: inline-block;
    animation: loaderPulse 1600ms ease-in-out 0ms infinite;
  }

  .loader-dot {
    color: var(--color-accent);
  }

  @keyframes loaderFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes loaderPulse {
    0%, 100% { transform: scale(1);    opacity: 1;   }
    50%       { transform: scale(1.08); opacity: 0.6; }
  }
</style>
