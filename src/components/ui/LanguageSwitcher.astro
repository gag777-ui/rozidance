---
import type { Lang } from '../../i18n/utils';

const currentLocale = (Astro.currentLocale ?? 'fr') as Lang;
const currentPath = Astro.url.pathname;

const nonDefaultLocales = ['en', 'nl', 'ru', 'hy'];

let cleanPath = currentPath;
for (const loc of nonDefaultLocales) {
  if (cleanPath.startsWith(`/${loc}/`)) {
    cleanPath = cleanPath.slice(loc.length + 1);
    break;
  }
  if (cleanPath === `/${loc}`) {
    cleanPath = '/';
    break;
  }
}

function langUrl(locale: string): string {
  if (locale === 'fr') return cleanPath;
  if (cleanPath === '/') return `/${locale}`;
  return `/${locale}${cleanPath}`;
}

const langs: { code: Lang; flag: string }[] = [
  { code: 'fr', flag: '🇫🇷' },
  { code: 'en', flag: '🇬🇧' },
  { code: 'nl', flag: '🇳🇱' },
  { code: 'ru', flag: '🇷🇺' },
  { code: 'hy', flag: '🇦🇲' },
];

const current = langs.find(l => l.code === currentLocale)!;
const others = langs.filter(l => l.code !== currentLocale);
---

<details class="lang-dropdown" id="lang-dropdown">
  <summary class="lang-trigger" aria-label="Changer de langue">
    <span>{current.flag}</span>
  </summary>

  <div class="lang-menu">
    {others.map((lang) => (
      <a
        href={langUrl(lang.code)}
        class="lang-option"
        hreflang={lang.code}
        aria-label={lang.code.toUpperCase()}
      >
        {lang.flag}
      </a>
    ))}
  </div>
</details>

<script>
  function initDropdown() {
    const dropdown = document.getElementById('lang-dropdown') as HTMLDetailsElement | null;
    if (!dropdown) return;
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) dropdown.open = false;
    });
  }
  initDropdown();
  document.addEventListener('astro:page-load', initDropdown);
</script>

<style>
  .lang-dropdown {
    position: relative;
    flex-shrink: 0;
  }

  .lang-trigger {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    border: 0.5px solid transparent;
    transition: border-color 200ms, background-color 200ms;
    user-select: none;
  }
  .lang-trigger::-webkit-details-marker { display: none; }
  .lang-trigger:hover {
    border-color: var(--color-border);
    background-color: var(--color-bg-card);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.375rem;
    background-color: var(--color-bg-card);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 8px 20px rgba(43, 31, 21, 0.1);
    z-index: 200;
    animation: menuOpen 160ms var(--ease-out-soft) both;
  }

  @keyframes menuOpen {
    from { opacity: 0; transform: translateY(-4px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .lang-option {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 30px;
    border-radius: 5px;
    font-size: 1.2rem;
    line-height: 1;
    text-decoration: none;
    transition: background-color 150ms;
  }

  .lang-option:hover {
    background-color: var(--color-bg-primary);
  }
</style>
