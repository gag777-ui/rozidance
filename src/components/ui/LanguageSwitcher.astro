---
import type { Lang } from '../../i18n/utils';

const currentLocale = (Astro.currentLocale ?? 'fr') as Lang;
const currentPath = Astro.url.pathname;

const nonDefaultLocales = ['en', 'nl', 'ru', 'hy'];

let cleanPath = currentPath;
for (const loc of nonDefaultLocales) {
  if (cleanPath.startsWith(`/${loc}/`)) {
    cleanPath = cleanPath.slice(loc.length + 1);
    break;
  }
  if (cleanPath === `/${loc}`) {
    cleanPath = '/';
    break;
  }
}

function langUrl(locale: string): string {
  if (locale === 'fr') return cleanPath;
  if (cleanPath === '/') return `/${locale}`;
  return `/${locale}${cleanPath}`;
}

const langs: { code: Lang; label: string }[] = [
  { code: 'fr', label: 'FR' },
  { code: 'en', label: 'EN' },
  { code: 'nl', label: 'NL' },
  { code: 'ru', label: 'RU' },
  { code: 'hy', label: 'HY' },
];

const current = langs.find(l => l.code === currentLocale)!;
const others = langs.filter(l => l.code !== currentLocale);
---

<details class="lang-dropdown" id="lang-dropdown">
  <summary class="lang-trigger" aria-label="Changer de langue">
    <span class="lang-current">{current.label}</span>
    <svg class="lang-chevron" width="8" height="5" viewBox="0 0 8 5" fill="none" aria-hidden="true">
      <path d="M1 1l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </summary>

  <div class="lang-menu">
    {others.map((lang) => (
      <a
        href={langUrl(lang.code)}
        class="lang-option"
        hreflang={lang.code}
      >
        {lang.label}
      </a>
    ))}
  </div>
</details>

<script>
  let _dropdownClick: ((e: MouseEvent) => void) | null = null;

  function initDropdown() {
    const dropdown = document.getElementById('lang-dropdown') as HTMLDetailsElement | null;
    if (!dropdown) return;

    if (_dropdownClick) document.removeEventListener('click', _dropdownClick);
    _dropdownClick = (e) => {
      if (!dropdown.contains(e.target as Node)) dropdown.open = false;
    };
    document.addEventListener('click', _dropdownClick);
  }

  document.addEventListener('astro:page-load', initDropdown);
</script>

<style>
  .lang-dropdown {
    position: relative;
    flex-shrink: 0;
  }

  .lang-trigger {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    border: 0.5px solid transparent;
    transition: border-color 200ms, background-color 200ms;
    user-select: none;
  }
  .lang-trigger::-webkit-details-marker { display: none; }
  .lang-trigger:hover {
    border-color: var(--color-border);
    background-color: var(--color-bg-card);
  }

  .lang-current {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .lang-chevron {
    color: var(--color-text-muted);
    transition: transform 220ms var(--ease-out-soft);
    flex-shrink: 0;
  }
  .lang-dropdown[open] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    display: flex;
    flex-direction: column;
    padding: 0.3rem;
    background-color: var(--color-bg-card);
    border: 0.5px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 6px 18px rgba(43, 31, 21, 0.1);
    z-index: 200;
    animation: menuOpen 150ms var(--ease-out-soft) both;
  }

  @keyframes menuOpen {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lang-option {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.35rem 0.6rem;
    border-radius: 4px;
    transition: color 150ms, background-color 150ms;
    white-space: nowrap;
  }
  .lang-option:hover {
    color: var(--color-text-primary);
    background-color: var(--color-bg-primary);
  }
</style>
