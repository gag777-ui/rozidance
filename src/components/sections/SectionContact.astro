---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
---

<section id="contact" class="section-contact" aria-labelledby="contact-title">
  <div class="section-container">
    <div class="section-header reveal-fade">
      <span class="eyebrow">{t.contact.eyebrow}</span>
      <h2 class="section-title" id="contact-title">{t.contact.title}</h2>
      <p class="contact-subtitle">{t.contact.subtitle}</p>
    </div>

    <div class="contact-cards">

      <!-- Instagram -->
      <a
        href="https://instagram.com/rozi.dance"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card reveal-scale"
        aria-label="Nous contacter sur Instagram @rozi.dance"
        style="transition-delay: 0ms"
      >
        <div class="card-accent-bar"></div>
        <div class="card-body">
          <span class="card-ordinal" aria-hidden="true">01</span>
          <div class="card-icon card-icon-instagram" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <defs>
                <linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#feda75"/>
                  <stop offset="25%" stop-color="#fa7e1e"/>
                  <stop offset="55%" stop-color="#d62976"/>
                  <stop offset="80%" stop-color="#962fbf"/>
                  <stop offset="100%" stop-color="#4f5bd5"/>
                </linearGradient>
              </defs>
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="url(#ig-grad)"/>
              <circle cx="12" cy="12" r="4.5" stroke="url(#ig-grad)"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="url(#ig-grad)" stroke="none"/>
            </svg>
          </div>
          <p class="card-label">{t.contact.instagram.label}</p>
          <p class="card-value">{t.contact.instagram.handle}</p>
          <span class="card-link">
            {t.contact.instagram.label}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="card-arrow-svg">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>

      <!-- Email -->
      <a
        href="mailto:abrahamyan.rose@mail.ru"
        class="contact-card reveal-scale"
        aria-label="Nous envoyer un e-mail à abrahamyan.rose@mail.ru"
        style="transition-delay: 120ms"
      >
        <div class="card-accent-bar"></div>
        <div class="card-body">
          <span class="card-ordinal" aria-hidden="true">02</span>
          <div class="card-icon card-icon-email" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </div>
          <p class="card-label">{t.contact.email.label}</p>
          <p class="card-value">{t.contact.email.address}</p>
          <span class="card-link">
            {t.contact.email.label}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="card-arrow-svg">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>

      <!-- Téléphone -->
      <a
        href="tel:+32486219896"
        class="contact-card reveal-scale"
        aria-label="Appeler le +32 486 21 98 96"
        style="transition-delay: 240ms"
      >
        <div class="card-accent-bar"></div>
        <div class="card-body">
          <span class="card-ordinal" aria-hidden="true">03</span>
          <div class="card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 10.8 19.79 19.79 0 01.07 2.18 2 2 0 012.06 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <p class="card-label">Téléphone</p>
          <p class="card-value">+32 486 21 98 96</p>
          <span class="card-link">
            Appeler
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="card-arrow-svg">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  .section-contact {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 50ch;
    text-align: center;
    line-height: 1.65;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .contact-card {
    position: relative;
    background-color: var(--color-bg-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 400ms var(--ease-out-soft), border-color 400ms var(--ease-out-soft), box-shadow 400ms var(--ease-out-soft);
  }

  .contact-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 32px rgba(193, 104, 71, 0.12);
  }

  .card-accent-bar {
    height: 3px;
    background: linear-gradient(to right, var(--color-accent), var(--color-gold));
    flex-shrink: 0;
  }

  .card-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
    position: relative;
  }

  .card-ordinal {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-family: var(--font-serif);
    font-size: 3.5rem;
    line-height: 1;
    color: var(--color-border);
    pointer-events: none;
    user-select: none;
    transition: color 400ms var(--ease-out-soft);
  }

  .contact-card:hover .card-ordinal {
    color: rgba(193, 104, 71, 0.12);
  }

  .card-icon {
    color: var(--color-accent);
    display: flex;
    flex-shrink: 0;
  }

  .card-icon-email {
    color: #EA4335;
  }

  .card-label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0;
    font-family: var(--font-sans);
  }

  .card-value {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--color-text-primary);
    margin: 0;
    flex: 1;
    line-height: 1.4;
    word-break: break-all;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: 0.25rem;
    transition: gap 250ms var(--ease-out-soft);
  }

  .contact-card:hover .card-link {
    gap: 0.75rem;
  }

  .card-arrow-svg {
    flex-shrink: 0;
    transition: transform 250ms var(--ease-out-soft);
  }

  .contact-card:hover .card-arrow-svg {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .contact-cards {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-inline: auto;
    }
  }

  @media (min-width: 600px) and (max-width: 768px) {
    .contact-cards {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
  }
</style>
