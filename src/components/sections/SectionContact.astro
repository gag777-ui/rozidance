---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
---

<section id="contact" class="section-contact" aria-labelledby="contact-title">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="eyebrow">{t.contact.eyebrow}</span>
      <h2 class="section-title" id="contact-title">{t.contact.title}</h2>
      <p class="contact-subtitle">{t.contact.subtitle}</p>
    </div>

    <div class="contact-cards">
      <!-- Instagram -->
      <a
        href="https://instagram.com/rozi.dance"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card card reveal"
        aria-label="Nous contacter sur Instagram @rozi.dance"
        style="transition-delay: 0ms"
      >
        <div class="contact-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <p class="contact-card-label">{t.contact.instagram.label}</p>
        <p class="contact-card-value">{t.contact.instagram.handle}</p>
        <span class="contact-card-arrow" aria-hidden="true">→</span>
      </a>

      <!-- Email -->
      <a
        href="mailto:contact@rozidance.be"
        class="contact-card card reveal"
        aria-label="Nous envoyer un e-mail à contact@rozidance.be"
        style="transition-delay: 120ms"
      >
        <div class="contact-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 7l10 7 10-7"/>
          </svg>
        </div>
        <p class="contact-card-label">{t.contact.email.label}</p>
        <p class="contact-card-value">{t.contact.email.address}</p>
        <span class="contact-card-arrow" aria-hidden="true">→</span>
      </a>

      <!-- Téléphone -->
      <a
        href="tel:+32486219896"
        class="contact-card card reveal"
        aria-label="Appeler le +32 486 21 98 96"
        style="transition-delay: 240ms"
      >
        <div class="contact-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 10.8 19.79 19.79 0 01.07 2.18 2 2 0 012.06 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </div>
        <p class="contact-card-label">Téléphone</p>
        <p class="contact-card-value">+32 486 21 98 96</p>
        <span class="contact-card-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .section-contact {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 50ch;
    text-align: center;
    line-height: 1.65;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 2rem;
    text-decoration: none;
    gap: 0.75rem;
    position: relative;
  }

  .contact-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    transition: background-color 400ms var(--ease-out-soft), transform 400ms var(--ease-out-soft);
    flex-shrink: 0;
  }

  .contact-card:hover .contact-icon {
    background-color: var(--color-accent-hover);
    transform: scale(1.06);
  }

  .contact-card-label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0;
  }

  .contact-card-value {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--color-text-primary);
    margin: 0;
  }

  .contact-card-arrow {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    font-size: 1rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 300ms, transform 300ms var(--ease-out-soft);
  }

  .contact-card:hover .contact-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @keyframes cardBreath {
    0%, 100% { box-shadow: 0 0 0 0px rgba(167, 94, 60, 0); }
    50%       { box-shadow: 0 0 0 4px rgba(167, 94, 60, 0.18); }
  }

  .contact-card:nth-child(1) { animation: cardBreath 2.4s ease-in-out infinite; animation-delay: 0s; }
  .contact-card:nth-child(2) { animation: cardBreath 2.4s ease-in-out infinite; animation-delay: 0.8s; }
  .contact-card:nth-child(3) { animation: cardBreath 2.4s ease-in-out infinite; animation-delay: 1.6s; }

  .contact-card:hover { animation-play-state: paused; }

  @media (max-width: 768px) {
    .contact-cards {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-inline: auto;
    }
  }

  @media (min-width: 600px) and (max-width: 768px) {
    .contact-cards {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
  }
</style>
