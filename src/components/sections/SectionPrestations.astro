---
import { getTranslations } from '../../i18n/utils';
const t = getTranslations('fr');

const icons = ['🎤', '💃', '🎓'] as const;
---

<section id="prestations" class="section-prestations" aria-labelledby="prestations-title">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="eyebrow">{t.prestations.eyebrow}</span>
      <h2 class="section-title" id="prestations-title">{t.prestations.title}</h2>
    </div>

    <div class="cards-grid">
      {t.prestations.items.map((item, i) => (
        <article class="card prestation-card reveal" style={`transition-delay: ${i * 120}ms`}>
          <div class="card-icon" aria-hidden="true">
            <span class="card-icon-inner">{icons[i]}</span>
          </div>
          <h3 class="card-title">{item.title}</h3>
          <p class="card-description">{item.description}</p>
          <a
            href={item.id === 'cours' ? '/cours' : `/#contact`}
            class="card-link"
            aria-label={`${item.link} — ${item.title}`}
          >
            {item.link}
            <span class="card-arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-prestations {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .prestation-card {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-icon-inner {
    font-size: 1.375rem;
    line-height: 1;
    filter: grayscale(1) brightness(5);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: auto;
    transition: gap 250ms var(--ease-out-soft);
  }

  .card-link:hover {
    gap: 0.625rem;
  }

  .card-arrow {
    transition: transform 250ms var(--ease-out-soft);
  }

  .card-link:hover .card-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
  }
</style>
