---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
const base = lang === 'fr' ? '' : `/${lang}`;

const svgIcons = [
  /* Alliances / mariage */
  `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="8" cy="12" r="5"/>
    <circle cx="16" cy="12" r="5"/>
  </svg>`,
  /* Microphone / chant */
  `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="9" y="2" width="6" height="11" rx="3"/>
    <path d="M5 10a7 7 0 0014 0"/>
    <line x1="12" y1="19" x2="12" y2="22"/>
    <line x1="8" y1="22" x2="16" y2="22"/>
  </svg>`,
  /* Livre / cours */
  `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
    <line x1="9" y1="7" x2="15" y2="7"/>
    <line x1="9" y1="11" x2="13" y2="11"/>
  </svg>`,
] as const;

const ordinals = ['01', '02', '03'] as const;
---

<section id="prestations" class="section-prestations" aria-labelledby="prestations-title">
  <div class="section-container">
    <div class="section-header reveal-fade">
      <span class="eyebrow">{t.prestations.eyebrow}</span>
      <h2 class="section-title" id="prestations-title">{t.prestations.title}</h2>
    </div>

    <div class="cards-grid">
      {t.prestations.items.map((item, i) => (
        <article class="prestation-card reveal" style={`transition-delay: ${i * 120}ms`}>
          <div class="card-accent-bar"></div>
          <div class="card-body">
            <span class="card-ordinal" aria-hidden="true">{ordinals[i]}</span>
            <div class="card-icon" set:html={svgIcons[i]} />
            <h3 class="card-title">{item.title}</h3>
            <p class="card-description">{item.description}</p>
            <a
              href={item.id === 'cours' ? `${base}/cours` : item.id === 'mariages' ? `${base}/mariages` : item.id === 'danse-evenementielle' ? `${base}/chant` : `${base || '/'}#contact`}
              class="card-link"
              aria-label={`${item.link} — ${item.title}`}
            >
              {item.link}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="card-arrow-svg">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-prestations {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .prestation-card {
    position: relative;
    background-color: var(--color-bg-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 400ms var(--ease-out-soft), border-color 400ms var(--ease-out-soft), box-shadow 400ms var(--ease-out-soft);
  }

  .prestation-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 32px rgba(193, 104, 71, 0.12);
  }

  .card-accent-bar {
    height: 3px;
    background: linear-gradient(to right, var(--color-accent), var(--color-gold));
    flex-shrink: 0;
  }

  .card-body {
    padding: 1.75rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    position: relative;
  }

  .card-ordinal {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-family: var(--font-serif);
    font-size: 3.5rem;
    line-height: 1;
    color: var(--color-border);
    pointer-events: none;
    user-select: none;
    transition: color 400ms var(--ease-out-soft);
  }

  .prestation-card:hover .card-ordinal {
    color: rgba(193, 104, 71, 0.12);
  }

  .card-icon {
    color: var(--color-accent);
    flex-shrink: 0;
    display: flex;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 250ms var(--ease-out-soft);
  }

  .card-link:hover {
    gap: 0.75rem;
  }

  .card-arrow-svg {
    flex-shrink: 0;
    transition: transform 250ms var(--ease-out-soft);
  }

  .card-link:hover .card-arrow-svg {
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
  }
</style>
