---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
---

<section id="temoignages" class="section-temoignages" aria-labelledby="temoignages-title">
  <div class="section-container">
    <div class="section-header reveal-fade">
      <span class="eyebrow">{t.temoignages.eyebrow}</span>
      <h2 class="section-title" id="temoignages-title">{t.temoignages.title}</h2>
    </div>

    <div class="temoignages-grid">
      {t.temoignages.items.map((item, i) => (
        <div class={`card-shell cs-${i % 3} reveal`} style={`transition-delay: ${i * 130}ms`} data-card>
          <article class={`card-core cc-${i % 3}`}>
            <div class="card-light"></div>
            <span class="temoignage-mark" aria-hidden="true">"</span>
            <p class="temoignage-text">{item.quote}</p>
            <footer class="temoignage-author">
              <span class="temoignage-name">{item.author}</span>
              <span class="temoignage-event">{item.event}</span>
            </footer>
          </article>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-temoignages {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .temoignages-grid {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 420px;
    margin-inline: auto;
  }

  @media (min-width: 600px) {
    .temoignages-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      max-width: 640px;
      gap: 1rem;
    }
  }

  @media (min-width: 900px) {
    .temoignages-grid {
      grid-template-columns: repeat(3, 1fr);
      max-width: 100%;
      gap: 1.25rem;
    }
  }

  /* ── Shell (double-bezel) ── */
  .card-shell {
    border-radius: 20px;
    padding: 5px;
    border: 0.5px solid rgba(229, 215, 190, 0.6);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9), 0 2px 8px rgba(43, 31, 21, 0.04);
    transform-style: preserve-3d;
    transform: perspective(900px) rotateX(0deg) rotateY(0deg);
    transition: transform 500ms var(--ease-out-soft), box-shadow 500ms var(--ease-out-soft);
    will-change: transform;
    -webkit-tap-highlight-color: transparent;
  }

  .cs-0 { background: rgba(168, 135, 83, 0.07); }
  .cs-1 { background: rgba(193, 104, 71, 0.07); }
  .cs-2 { background: rgba(122, 92, 32, 0.06); }

  /* ── Core ── */
  .card-core {
    border-radius: 15px;
    padding: 1.5rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
    overflow: hidden;
  }

  .cc-0 { background: linear-gradient(145deg, #FEFCF8 0%, #EDDEB8 100%); }
  .cc-1 { background: linear-gradient(145deg, #FEFCF8 0%, #F0CBBA 100%); }
  .cc-2 { background: linear-gradient(145deg, #FEFCF8 0%, #E6D8A8 100%); }

  .card-light {
    position: absolute; inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at var(--lx, 28%) var(--ly, 22%), rgba(255,255,255,0.38) 0%, rgba(255,255,255,0.1) 35%, transparent 65%);
    border-radius: inherit;
    transition: background 80ms linear;
  }

  /* ── Contenu ── */
  .temoignage-mark {
    font-family: var(--font-serif);
    font-size: 3rem;
    line-height: 0.75;
    color: var(--color-gold);
    opacity: 0.4;
    display: block;
    position: relative;
  }

  .temoignage-text {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text-primary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
    position: relative;
  }

  .temoignage-author {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 1rem;
    border-top: 0.5px solid rgba(229, 215, 190, 0.7);
    position: relative;
  }

  .temoignage-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .temoignage-event {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .card-shell { transition: none; }
    .card-light { transition: none; }
  }
</style>
