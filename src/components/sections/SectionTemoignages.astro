---
import { getTranslations } from '../../i18n/utils';
const t = getTranslations('fr');
---

<section id="temoignages" class="section-temoignages" aria-labelledby="temoignages-title">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="eyebrow">{t.temoignages.eyebrow}</span>
      <h2 class="section-title" id="temoignages-title">{t.temoignages.title}</h2>
    </div>

    <div class="temoignages-grid">
      {t.temoignages.items.map((item, i) => (
        <article class="temoignage-card card reveal" style={`transition-delay: ${i * 110}ms`}>
          <span class="temoignage-mark" aria-hidden="true">"</span>
          <p class="temoignage-text">{item.quote}</p>
          <footer class="temoignage-author">
            <span class="temoignage-name">{item.author}</span>
            <span class="temoignage-event">{item.event}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-temoignages {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .temoignages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .temoignage-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .temoignage-mark {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    line-height: 0.75;
    color: var(--color-gold);
    opacity: 0.35;
    display: block;
  }

  .temoignage-text {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-style: italic;
    color: var(--color-text-primary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .temoignage-author {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 1.25rem;
    border-top: 0.5px solid var(--color-border);
  }

  .temoignage-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .temoignage-event {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .temoignages-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }
</style>
