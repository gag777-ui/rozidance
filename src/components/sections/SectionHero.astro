---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
const base = lang === 'fr' ? '' : `/${lang}`;

const heroVideoId = import.meta.env.PUBLIC_HERO_VIDEO_ID || 'dQw4w9WgXcQ';
const ytParams = `autoplay=1&mute=1&loop=1&playlist=${heroVideoId}&controls=0&modestbranding=1&showinfo=0&rel=0&iv_load_policy=3&disablekb=1&playsinline=1&fs=0`;
---

<section class="hero-section" aria-labelledby="hero-title">

  <!-- Vidéo fond plein écran (desktop uniquement) -->
  <div class="hero-video-bg" aria-hidden="true">
    <iframe
      class="hero-bg-iframe"
      data-src={`https://www.youtube-nocookie.com/embed/${heroVideoId}?${ytParams}`}
      title=""
      tabindex="-1"
      style="border:none"
      allow="autoplay; encrypted-media"
      disablepictureinpicture
    ></iframe>
    <div class="hero-filter"></div>
  </div>

  <!-- Motif géométrique watermark (desktop) -->
  <div class="hero-pattern" aria-hidden="true">
    <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="hero-pattern-svg">
      <g stroke="#ffffff" stroke-width="0.8" fill="none">
        <polygon points="250,80 265,115 305,115 272,138 285,175 250,152 215,175 228,138 195,115 235,115"/>
        <polygon points="250,40 270,80 250,120 230,80"/>
        <polygon points="370,160 410,180 370,200 330,180"/>
        <polygon points="130,160 170,180 130,200 90,180"/>
        <rect x="180" y="60" width="140" height="140" transform="rotate(45 250 130)" stroke-width="0.5"/>
        <rect x="200" y="80" width="100" height="100" transform="rotate(45 250 130)" stroke-width="0.5"/>
        <line x1="200" y1="0" x2="200" y2="500" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="300" y1="0" x2="300" y2="500" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="0" y1="200" x2="500" y2="200" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="0" y1="300" x2="500" y2="300" stroke-width="0.3" stroke-dasharray="4 12"/>
      </g>
    </svg>
  </div>

  <!-- Layout interne -->
  <div class="hero-inner section-container">

    <!-- Texte -->
    <div class="hero-text">
      <span class="hero-eyebrow">
        <a href="https://www.youtube.com/watch?v=kTIPlgRoWUE" target="_blank" rel="noopener noreferrer" class="eyebrow-link">{t.hero.eyebrowChant}</a>
        {' · '}
        <a href="https://www.instagram.com/reel/DQhuDa2jATw/?igsh=c2k0OXV1M2JkbXBh" target="_blank" rel="noopener noreferrer" class="eyebrow-link">{t.hero.eyebrowDanse}</a>
        {' · '}
        <a href="https://www.instagram.com/band_hay?igsh=cDRxNjVmanEwMWho" target="_blank" rel="noopener noreferrer" class="eyebrow-link">{t.hero.eyebrowMusique}</a>
        {' · '}
        <a href={`${base}/galerie`} class="eyebrow-link">{t.hero.eyebrowGalerie}</a>
      </span>

      <h1 class="hero-title" id="hero-title">
        <span class="hero-line">{t.hero.line1}</span>
        <span class="hero-line">{t.hero.line2}</span>
        <em class="hero-line hero-italic">{t.hero.line3italic}</em>
      </h1>

      <p class="hero-subtitle">{t.hero.subtitle}</p>

      <div class="hero-actions">
        <a href="#contact" class="btn-primary">{t.hero.ctaPrimary}</a>
        <a href="#prestations" class="hero-btn-ghost">{t.hero.ctaSecondary}</a>
      </div>
    </div>

    <!-- Widget vidéo (mobile uniquement) -->
    <div class="hero-video-wrap">
      <div class="hero-video-frame">
        <iframe
          class="hero-widget-iframe"
          data-src={`https://www.youtube-nocookie.com/embed/${heroVideoId}?${ytParams}`}
          title="Rozi Dance — vidéo de présentation"
          tabindex="-1"
          style="border:none"
          allow="autoplay; encrypted-media"
          loading="lazy"
          aria-hidden="true"
          disablepictureinpicture
        ></iframe>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── BASE (toutes tailles) — vidéo fond activée partout ── */
  .hero-section {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 5rem 3rem;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  /* Vidéo fond */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .hero-bg-iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 56.25vw;
    min-height: 100%;
    min-width: 177.78vh;
    border: none;
    pointer-events: none;
  }

  /* Filtre sombre par-dessus la vidéo */
  .hero-filter {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(20,10,5,0.62) 0%, transparent 48%),
      radial-gradient(ellipse 120% 100% at 50% 50%, rgba(20,10,5,0.5) 0%, rgba(20,10,5,0.82) 100%);
    z-index: 1;
  }

  .hero-pattern { display: none; }

  /* Contenu au-dessus de la vidéo */
  .hero-inner {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr;
    text-align: center;
    width: 100%;
    gap: 0;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  /* Widget vidéo mobile supprimé — on utilise la vidéo fond */
  .hero-video-wrap { display: none; }

  /* Texte blanc sur fond sombre */
  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.72);
    display: block;
  }

  @keyframes eyebrowBreath {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .eyebrow-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    animation: eyebrowBreath 2.4s ease-in-out infinite;
  }

  .hero-eyebrow a:nth-child(1) { animation-delay: 0s; }
  .hero-eyebrow a:nth-child(2) { animation-delay: 0.6s; }
  .hero-eyebrow a:nth-child(3) { animation-delay: 1.2s; }
  .hero-eyebrow a:nth-child(4) { animation-delay: 1.8s; }

  .eyebrow-link:hover {
    opacity: 1;
    animation-play-state: paused;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    font-size: clamp(2.75rem, 10vw, 4rem);
    line-height: 1.05;
    color: #fff;
    text-shadow: 0 2px 20px rgba(20,10,5,0.5);
    margin: 0;
  }

  .hero-line { display: block; }

  .hero-italic {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.78);
    max-width: 38ch;
    line-height: 1.65;
    margin: 0;
    text-shadow: 0 1px 8px rgba(20,10,5,0.4);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: transparent;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.05em;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-btn);
    border: 0.5px solid rgba(255,255,255,0.6);
    transition: border-color 400ms var(--ease-out-soft), background-color 400ms var(--ease-out-soft);
    cursor: pointer;
    text-decoration: none;
  }
  .hero-btn-ghost:hover {
    border-color: #fff;
    background-color: rgba(255,255,255,0.1);
  }

  /* ── DESKTOP ── */
  @media (min-width: 901px) {
    .hero-section {
      min-height: 100vh;
      padding-block: 0;
    }

    .hero-pattern {
      display: block;
      position: absolute;
      top: 50%;
      right: -60px;
      transform: translateY(-50%);
      width: 520px;
      height: 520px;
      pointer-events: none;
      opacity: 0.07;
      z-index: 2;
    }
    .hero-pattern-svg { width: 100%; height: 100%; }

    .hero-inner {
      padding-block: 6rem;
    }

    .hero-title {
      font-size: clamp(3.5rem, 8vw, 7rem);
      line-height: 1.0;
      text-shadow: 0 2px 24px rgba(20,10,5,0.45);
    }

    .hero-subtitle {
      font-size: clamp(1rem, 1.5vw, 1.125rem);
      max-width: 44ch;
    }
  }
</style>

<script>
  function loadHeroVideos() {
    document.querySelectorAll<HTMLIFrameElement>('.hero-bg-iframe, .hero-widget-iframe').forEach((iframe) => {
      const target = iframe.dataset.src;
      if (target && iframe.src !== target) {
        iframe.src = target;
      }
    });
  }

  // Premier chargement : attend window.load pour ne pas bloquer le LCP
  window.addEventListener('load', loadHeroVideos);
  // Navigations View Transitions : s'exécute dès le swap DOM (avant les animations)
  document.addEventListener('astro:after-swap', loadHeroVideos);
</script>
