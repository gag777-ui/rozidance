---
import { getTranslations } from '../../i18n/utils';
const t = getTranslations('fr');

// TODO: Remplacer par l'ID de la vraie vidéo Rozi Dance fournie par Gago
const heroVideoId = import.meta.env.PUBLIC_HERO_VIDEO_ID || 'dQw4w9WgXcQ';
---

<section class="hero-section" aria-labelledby="hero-title">
  <!-- Geometric watermark -->
  <div class="hero-pattern" aria-hidden="true">
    <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="hero-pattern-svg">
      <g stroke="#A88753" stroke-width="0.8" fill="none">
        <polygon points="250,80 265,115 305,115 272,138 285,175 250,152 215,175 228,138 195,115 235,115"/>
        <polygon points="250,40 270,80 250,120 230,80"/>
        <polygon points="370,160 410,180 370,200 330,180"/>
        <polygon points="130,160 170,180 130,200 90,180"/>
        <rect x="180" y="60" width="140" height="140" transform="rotate(45 250 130)" stroke-width="0.5"/>
        <rect x="200" y="80" width="100" height="100" transform="rotate(45 250 130)" stroke-width="0.5"/>
        <line x1="200" y1="0" x2="200" y2="500" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="300" y1="0" x2="300" y2="500" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="0" y1="200" x2="500" y2="200" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="0" y1="300" x2="500" y2="300" stroke-width="0.3" stroke-dasharray="4 12"/>
      </g>
    </svg>
  </div>

  <div class="section-container hero-inner">
    <!-- Text side -->
    <div class="hero-text">
      <span class="eyebrow">{t.hero.eyebrow}</span>

      <h1 class="hero-title" id="hero-title">
        <span class="hero-line">{t.hero.line1}</span>
        <span class="hero-line">{t.hero.line2}</span>
        <em class="hero-line hero-italic">{t.hero.line3italic}</em>
      </h1>

      <p class="hero-subtitle">{t.hero.subtitle}</p>

      <div class="hero-actions">
        <a href="#contact" class="btn-primary">{t.hero.ctaPrimary}</a>
        <a href="#prestations" class="btn-ghost">{t.hero.ctaSecondary}</a>
      </div>
    </div>

    <!-- Video side -->
    <div class="hero-video-wrap">
      <!-- Cadre décoratif laurier-rose -->
      <div class="video-deco-wrap">
        <svg class="video-deco-svg" viewBox="0 0 580 346" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <!-- Motif laurier-rose : une branche avec feuilles + fleur, conçu depuis (0,0) vers le coin extérieur -->
            <g id="laurier-corner">
              <!-- Tige principale -->
              <path d="M 0,0 C -10,-8 -18,-20 -24,-38" stroke="#B89060" stroke-width="0.9" stroke-linecap="round"/>
              <!-- Feuille 1 (basse) -->
              <path d="M -7,-7 C -17,-15 -19,-7 -11,-3 C -8,-1 -7,-7 Z" fill="#8A9E78"/>
              <!-- Feuille 2 (milieu) -->
              <path d="M -15,-19 C -27,-25 -26,-16 -18,-13 C -15,-12 -15,-19 Z" fill="#8A9E78"/>
              <!-- Feuille 3 (petite, côté opposé) -->
              <path d="M -10,-14 C -8,-24 -2,-22 -3,-16 C -3,-13 -10,-14 Z" fill="#8A9E78" opacity="0.7"/>
              <!-- Tige secondaire + bouton de fleur -->
              <path d="M -11,-13 C -16,-20 -18,-28 -18,-34" stroke="#B89060" stroke-width="0.7" stroke-linecap="round"/>
              <ellipse cx="-18" cy="-37" rx="2.5" ry="5" fill="#D4949A" transform="rotate(-15,-18,-37)"/>
              <!-- Fleur épanouie en bout de tige -->
              <g transform="translate(-24,-38)">
                <ellipse cx="0" cy="-5" rx="2" ry="3.8" fill="#C8848C"/>
                <ellipse cx="0" cy="-5" rx="2" ry="3.8" fill="#C8848C" transform="rotate(72,0,0)"/>
                <ellipse cx="0" cy="-5" rx="2" ry="3.8" fill="#C8848C" transform="rotate(144,0,0)"/>
                <ellipse cx="0" cy="-5" rx="2" ry="3.8" fill="#C8848C" transform="rotate(216,0,0)"/>
                <ellipse cx="0" cy="-5" rx="2" ry="3.8" fill="#C8848C" transform="rotate(288,0,0)"/>
                <circle cx="0" cy="0" r="2" fill="#ECC890"/>
              </g>
              <!-- Petite feuille terminale -->
              <path d="M -18,-32 C -26,-38 -24,-30 -18,-28 C -16,-27 -18,-32 Z" fill="#8A9E78" opacity="0.65"/>
            </g>
          </defs>

          <!-- Coin haut-gauche (0,0 du frame = 30,30 du SVG) -->
          <use href="#laurier-corner" transform="translate(30,30)" opacity="0.6"/>
          <!-- Coin haut-droit (miroir horizontal) -->
          <use href="#laurier-corner" transform="translate(550,30) scale(-1,1)" opacity="0.6"/>
          <!-- Coin bas-gauche (miroir vertical) -->
          <use href="#laurier-corner" transform="translate(30,316) scale(1,-1)" opacity="0.6"/>
          <!-- Coin bas-droit (miroir double) -->
          <use href="#laurier-corner" transform="translate(550,316) scale(-1,-1)" opacity="0.6"/>

          <!-- Petits points décoratifs dorés sur les côtés (subtils) -->
          <circle cx="290" cy="2" r="1.2" fill="#B89060" opacity="0.35"/>
          <circle cx="282" cy="2" r="0.8" fill="#B89060" opacity="0.25"/>
          <circle cx="298" cy="2" r="0.8" fill="#B89060" opacity="0.25"/>
          <circle cx="290" cy="344" r="1.2" fill="#B89060" opacity="0.35"/>
          <circle cx="282" cy="344" r="0.8" fill="#B89060" opacity="0.25"/>
          <circle cx="298" cy="344" r="0.8" fill="#B89060" opacity="0.25"/>
        </svg>

        <div class="hero-video-frame">
        <!-- Subtle overlay -->
        <div class="video-overlay" aria-hidden="true"></div>

        <!-- Iframe légèrement surdimensionné pour clipper le logo YT -->
        <iframe
          class="hero-iframe"
          src={`https://www.youtube.com/embed/${heroVideoId}?autoplay=1&mute=1&loop=1&playlist=${heroVideoId}&controls=0&modestbranding=1&showinfo=0&rel=0&iv_load_policy=3&disablekb=1&playsinline=1`}
          title="Rozi Dance — vidéo de présentation"
          style="border:none"
          allow="autoplay; encrypted-media"
          loading="lazy"
          aria-hidden="true"
        ></iframe>
        </div><!-- /hero-video-frame -->
      </div><!-- /video-deco-wrap -->
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-block: 5rem 4rem;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    top: -60px;
    right: -60px;
    width: 520px;
    height: 520px;
    pointer-events: none;
    opacity: 0.12;
  }

  .hero-pattern-svg {
    width: 100%;
    height: 100%;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
    width: 100%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .eyebrow {
    margin-bottom: 0.25rem;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 1.05;
    color: var(--color-text-primary);
    margin: 0;
  }

  .hero-line {
    display: block;
  }

  .hero-italic {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 40ch;
    line-height: 1.65;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  /* Video widget */
  .hero-video-wrap {
    display: flex;
    justify-content: center;
  }

  .video-deco-wrap {
    position: relative;
    padding: 28px;
    width: 100%;
    max-width: 576px;
  }

  .video-deco-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 2;
  }

  .hero-video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    border: 1px solid var(--color-gold);
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(43, 31, 21, 0.12);
  }

  .hero-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    /* Gradient terracotta léger + cache coin bas-droite pour le logo YT */
    background:
      linear-gradient(180deg, rgba(193,104,71,0) 60%, rgba(193,104,71,0.08) 100%),
      radial-gradient(ellipse 80px 40px at 100% 100%, #F7F1E6 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Mobile layout */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-video-wrap {
      order: 1;
    }

    /* Pas de padding déco sur mobile — trop chargé en petit */
    .video-deco-wrap {
      padding: 0;
      max-width: 100%;
    }

    .video-deco-svg {
      display: none;
    }

    .hero-text {
      align-items: center;
    }

    .hero-subtitle {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .hero-section {
      min-height: auto;
      padding-block: 2.5rem 2rem;
    }

    .hero-video-frame {
      max-width: 100%;
    }
  }
</style>
