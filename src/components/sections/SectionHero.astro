---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);
const base = lang === 'fr' ? '' : `/${lang}`;

---

<section class="hero-section" aria-labelledby="hero-title">

  <!-- Fond hero : vidéo MP4 auto-hébergée -->
  <div class="hero-video-bg" aria-hidden="true">
    <video
      class="hero-bg-video"
      autoplay
      muted
      loop
      playsinline
      disablepictureinpicture
      preload="none"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-filter"></div>
  </div>

  <!-- Motif géométrique watermark (desktop) -->
  <div class="hero-pattern" aria-hidden="true">
    <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="hero-pattern-svg">
      <g stroke="#ffffff" stroke-width="0.8" fill="none">
        <polygon points="250,80 265,115 305,115 272,138 285,175 250,152 215,175 228,138 195,115 235,115"/>
        <polygon points="250,40 270,80 250,120 230,80"/>
        <polygon points="370,160 410,180 370,200 330,180"/>
        <polygon points="130,160 170,180 130,200 90,180"/>
        <rect x="180" y="60" width="140" height="140" transform="rotate(45 250 130)" stroke-width="0.5"/>
        <rect x="200" y="80" width="100" height="100" transform="rotate(45 250 130)" stroke-width="0.5"/>
        <line x1="200" y1="0" x2="200" y2="500" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="300" y1="0" x2="300" y2="500" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="0" y1="200" x2="500" y2="200" stroke-width="0.3" stroke-dasharray="4 12"/>
        <line x1="0" y1="300" x2="500" y2="300" stroke-width="0.3" stroke-dasharray="4 12"/>
      </g>
    </svg>
  </div>

  <!-- Layout interne -->
  <div class="hero-inner section-container">

    <!-- Texte -->
    <div class="hero-text">
      <h1 class="hero-title" id="hero-title">
        <span class="hero-line">{t.hero.line1}</span>
        <span class="hero-line">{t.hero.line2}</span>
        <em class="hero-line hero-italic" id="hero-italic" aria-label={`${t.hero.line3a} · ${t.hero.line3italic}`}></em>
      </h1>


    </div>

  </div>
</section>

<style>
  /* ── BASE (toutes tailles) — vidéo fond activée partout ── */
  .hero-section {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 5rem 3rem;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  /* Vidéo fond */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  /* Vidéo fond */
  .hero-bg-video {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  /* Filtre sombre par-dessus la vidéo */
  .hero-filter {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(20,10,5,0.62) 0%, transparent 48%),
      radial-gradient(ellipse 120% 100% at 50% 50%, rgba(20,10,5,0.5) 0%, rgba(20,10,5,0.82) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-pattern { display: none; }

  /* Contenu au-dessus de la vidéo */
  .hero-inner {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr;
    text-align: center;
    width: 100%;
    gap: 0;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  /* Widget vidéo mobile supprimé — on utilise la vidéo fond */
  .hero-video-wrap { display: none; }

  /* ── Animations d'entrée du titre ── */
  @keyframes heroWordIn {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroLineIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroSignatureIn {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.92);
      filter: blur(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    font-size: clamp(2.25rem, 9vw, 3.75rem);
    line-height: 1.08;
    color: #fff;
    text-shadow: 0 2px 20px rgba(20,10,5,0.5);
    margin: 0;
  }

  .hero-line { display: block; }

  /* "Bienvenu" — apparaît en premier, juste après le loader */
  .hero-line:nth-child(1) {
    animation: heroWordIn 650ms var(--ease-out-soft) 500ms both;
  }

  /* "dans le monde de" — suit avec du recul */
  .hero-line:nth-child(2) {
    animation: heroLineIn 700ms var(--ease-out-soft) 950ms both;
    color: rgba(220, 190, 165, 0.88);
  }

  /* "Rozi · Dance" — géré par le typewriter JS */
  .hero-italic {
    opacity: 0;
  }

  .hero-line:first-child {
    font-size: clamp(1.125rem, 4vw, 1.5rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: var(--font-sans);
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    margin-bottom: 0.3em;
  }

  .hero-italic {
    color: #CE8698;
    font-style: italic;
    font-size: clamp(3rem, 12vw, 5.5rem);
    line-height: 1.0;
    margin-top: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25em;
    min-height: 1.1em;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-cursor {
    display: inline-block;
    font-style: normal;
    font-weight: 300;
    color: rgba(255,255,255,0.7);
    animation: cursorBlink 0.6s step-end infinite;
    margin-left: 2px;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.78);
    max-width: 38ch;
    line-height: 1.65;
    margin: 0;
    text-shadow: 0 1px 8px rgba(20,10,5,0.4);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: transparent;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.05em;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-btn);
    border: 0.5px solid rgba(255,255,255,0.6);
    transition: border-color 400ms var(--ease-out-soft), background-color 400ms var(--ease-out-soft);
    cursor: pointer;
    text-decoration: none;
  }
  .hero-btn-ghost:hover {
    border-color: #fff;
    background-color: rgba(255,255,255,0.1);
  }

  /* ── DESKTOP ── */
  @media (min-width: 901px) {
    .hero-section {
      min-height: 100vh;
      padding-block: 0;
    }

    .hero-pattern {
      display: block;
      position: absolute;
      top: 50%;
      right: -60px;
      transform: translateY(-50%);
      width: 520px;
      height: 520px;
      pointer-events: none;
      opacity: 0.07;
      z-index: 2;
    }
    .hero-pattern-svg { width: 100%; height: 100%; }

    .hero-inner {
      padding-block: 6rem;
    }

    .hero-title {
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 1.05;
      text-shadow: 0 2px 24px rgba(20,10,5,0.45);
    }

    .hero-line:first-child {
      font-size: clamp(0.875rem, 1.2vw, 1.125rem);
      margin-bottom: 0.4em;
    }

    .hero-italic {
      font-size: clamp(4rem, 9vw, 8rem);
    }

    .hero-subtitle {
      font-size: clamp(1rem, 1.5vw, 1.125rem);
      max-width: 44ch;
    }
  }
</style>

<script>
  const FULL_TEXT = 'Rozi · Dance';
  const CHAR_DELAY = 45;
  const START_DELAY = 900;

  function initHeroTypewriter() {
    const el = document.getElementById('hero-italic') as HTMLElement | null;
    if (!el) return;

    el.textContent = '';
    el.style.opacity = '1';

    let i = 0;

    function typeNext() {
      if (i >= FULL_TEXT.length) return;
      el.textContent += FULL_TEXT[i];
      i++;
      const jitter = (Math.random() - 0.5) * 50;
      const pause = i === 4 ? 320 : CHAR_DELAY + jitter;
      setTimeout(typeNext, pause);
    }

    setTimeout(typeNext, START_DELAY);
  }

  document.addEventListener('astro:page-load', initHeroTypewriter);
</script>

