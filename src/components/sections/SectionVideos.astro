---
import { getTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
const lang = (Astro.currentLocale ?? 'fr') as Lang;
const t = getTranslations(lang);

const videos = [
  {
    id: 'zTQRoFT6tX4',
    title: 'Rozi Dance',
    thumbnail: 'https://img.youtube.com/vi/zTQRoFT6tX4/hqdefault.jpg',
  },
  {
    id: 'xa3-8ONanC4',
    title: 'Rozi Dance',
    thumbnail: 'https://img.youtube.com/vi/xa3-8ONanC4/hqdefault.jpg',
  },
  {
    id: 'mO7R2CxR5mQ',
    title: 'Rozi Dance',
    thumbnail: 'https://img.youtube.com/vi/mO7R2CxR5mQ/hqdefault.jpg',
  },
];
---

<section id="videos" class="section-videos" aria-labelledby="videos-title">
  <div class="section-container">
    <div class="section-header reveal-fade">
      <span class="eyebrow">{t.videos.eyebrow}</span>
      <h2 class="section-title" id="videos-title">
        <span class="title-passion-wrap">
          {t.videos.title}
          <svg class="passion-heart" viewBox="0 0 22 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M11 23.5C11 23.5 1.5 16.5 1.5 9.5C1.5 5.91 4.41 3 8 3C9.6 3 11 3.9 11 3.9C11 3.9 12.4 3 14 3C17.59 3 20.5 5.91 20.5 9.5C20.5 16.5 11 23.5 11 23.5Z"
              stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
          </svg>
        </span>
      </h2>
    </div>

    <div class="videos-grid">
      {videos.map((video, i) => (
        <div class="video-card card reveal" style={`transition-delay: ${i * 120}ms`}>
          <button
            class="video-thumb-btn"
            data-video-id={video.id}
            aria-label={`Lire la vidéo : ${video.title}`}
          >
            <div class="video-thumb-wrap">
              <img
                src={video.thumbnail}
                alt={`Aperçu : ${video.title}`}
                loading="lazy"
                decoding="async"
                class="video-thumb"
                width="480"
                height="270"
                data-fallback="/images/video-placeholder.webp"
              />
              <!-- Play button -->
              <div class="video-play-btn" aria-hidden="true">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <circle cx="24" cy="24" r="24" fill="rgba(43,31,21,0.6)"/>
                  <polygon points="19,14 37,24 19,34" fill="#fff"/>
                </svg>
              </div>
            </div>
          </button>

          <!-- Inline player (hidden by default) -->
          <div class="video-player" hidden>
            <div class="video-player-inner">
              <iframe
                class="video-iframe"
                src=""
                data-src={`https://www.youtube.com/embed/${video.id}?autoplay=1&rel=0&modestbranding=1`}
                title={video.title}
                style="border:none"
                allow="autoplay; encrypted-media; fullscreen"
                allowfullscreen
              ></iframe>
              <button class="video-close-btn" aria-label="Fermer la vidéo">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <line x1="2" y1="2" x2="18" y2="18" stroke="currentColor" stroke-width="1.5"/>
                  <line x1="18" y1="2" x2="2" y2="18" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </button>
            </div>
          </div>

          <div class="video-card-body">
            <p class="video-title">{video.title}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="videos-footer reveal-fade">
      <a
        href="https://www.youtube.com/@luarozifreedomband/videos"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost videos-yt-btn"
        aria-label="Voir toute la chaîne YouTube Rozi Dance"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Voir toute la chaîne <span class="yt-label-red">YouTube</span>
      </a>
    </div>
  </div>
</section>

<script>
  function initVideos() {
    document.querySelectorAll<HTMLElement>('.video-thumb-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.video-card');
        if (!card) return;

        const player = card.querySelector('.video-player') as HTMLElement | null;
        const iframe = card.querySelector('.video-iframe') as HTMLIFrameElement | null;

        if (!player || !iframe) return;

        const dataSrc = iframe.getAttribute('data-src');
        if (dataSrc) iframe.src = dataSrc;
        player.hidden = false;
        btn.hidden = true;
      });
    });

    document.querySelectorAll<HTMLElement>('.video-close-btn').forEach((closeBtn) => {
      closeBtn.addEventListener('click', () => {
        const card = closeBtn.closest('.video-card');
        if (!card) return;

        const player = card.querySelector('.video-player') as HTMLElement | null;
        const iframe = card.querySelector('.video-iframe') as HTMLIFrameElement | null;
        const thumbBtn = card.querySelector('.video-thumb-btn') as HTMLElement | null;

        if (player) {
          player.hidden = true;
          if (iframe) iframe.src = '';
        }
        if (thumbBtn) thumbBtn.hidden = false;
      });
    });
  }

  document.addEventListener('astro:page-load', initVideos);
</script>

<style>
  .section-videos {
    padding-block: var(--spacing-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    color: var(--color-text-primary);
    margin: 0;
  }

  .title-passion-wrap {
    position: relative;
    display: inline-block;
  }

  .passion-heart {
    position: absolute;
    right: -0.22em;
    top: 0.08em;
    width: 0.3em;
    height: 0.36em;
    color: #C96876;
    stroke: currentColor;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .video-card {
    overflow: hidden;
    padding: 0;
  }

  .video-thumb-btn {
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
  }

  .video-thumb-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms var(--ease-out-soft);
  }

  .video-thumb-btn:hover .video-thumb {
    transform: scale(1.04);
  }

  .video-play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 300ms;
  }

  .video-thumb-btn:hover .video-play-btn {
    opacity: 0.85;
  }

  .video-player {
    aspect-ratio: 16 / 9;
    position: relative;
  }

  .video-player-inner {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .video-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    aspect-ratio: 16 / 9;
  }

  .video-close-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(43, 31, 21, 0.7);
    color: #fff;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
  }

  .video-card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .video-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.4;
  }

  .videos-footer {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .videos-yt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  .yt-label-red {
    color: #ff0000;
  }

  @media (max-width: 900px) {
    .videos-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .videos-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
  }
</style>
